@model Resort_Hub.ViewModels.Admin.DashboardViewModel;
@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-dashboard.css" />
    @* <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" /> *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" /> 
}

<div class="dashboard-container">
    <!-- Page Header -->
    <div class="dashboard-header mb-4">
        <h1 class="display-6 fw-bold">
            <i class="fas fa-chart-line me-3 text-primary"></i>Dashboard
        </h1>
        <p class="text-muted">Welcome back! Here's what's happening with your resort today.</p>
    </div>

    <!-- Stats Cards Row -->
    <div class="row g-4 mb-5">
        <!-- Total Bookings Card -->
        <div class="col-xl-3 col-md-6">
            <div class="stat-card booking-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="stat-label mb-1">Total Bookings</p>
                            <h2 class="stat-value mb-2">@Model.TotalBookings.ToString("N0")</h2>
                            <div class="stat-change @(Model.BookingsChange >= 0 ? "positive" : "negative")">
                                <i class="fas @(Model.BookingsChange >= 0 ? "fa-arrow-up" : "fa-arrow-down") me-1"></i>
                                <span>@Math.Abs(Model.BookingsChange).ToString("N0") since last month</span>
                            </div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-calendar-check"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Users Card -->
        <div class="col-xl-3 col-md-6">
            <div class="stat-card users-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="stat-label mb-1">Total Users</p>
                            <h2 class="stat-value mb-2">@Model.TotalUsers.ToString("N0")</h2>
                            <div class="stat-change @(Model.UsersChange >= 0 ? "positive" : "negative")">
                                <i class="fas @(Model.UsersChange >= 0 ? "fa-arrow-up" : "fa-arrow-down") me-1"></i>
                                <span>@Math.Abs(Model.UsersChange).ToString("N0") since last month</span>
                            </div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Revenue Card -->
        <div class="col-xl-3 col-md-6">
            <div class="stat-card revenue-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="stat-label mb-1">Total Revenue</p>
                            <h2 class="stat-value mb-2">@Model.TotalRevenue.ToString()</h2>
                            <div class="stat-change @(Model.RevenueChange >= 0 ? "positive" : "negative")">
                                <i class="fas @(Model.RevenueChange >= 0 ? "fa-arrow-up" : "fa-arrow-down") me-1"></i>
                                <span>@Math.Abs(Model.RevenueChange).ToString() since last month</span>
                            </div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-dollar-sign"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Average Booking Value Card (Extra) -->
        <div class="col-xl-3 col-md-6">
            <div class="stat-card avg-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="stat-label mb-1">Avg. Booking Value</p>
                            <h2 class="stat-value mb-2">@Model.AverageBookingValue.ToString()</h2>
                            <div class="stat-change">
                                <i class="fas fa-chart-line me-1"></i>
                                <span>Last 30 days</span>
                            </div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-chart-simple"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart Section -->
    <div class="row">
        <div class="col-12">
            <div class="chart-card">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap">
                        <div>
                            <h4 class="mb-1 fw-bold">
                                <i class="fas fa-chart-line me-2 text-primary"></i>
                                New Members And Bookings In Past 30 Days
                            </h4>
                            <p class="text-muted mb-0">Daily booking trends and member registrations</p>
                        </div>
                        <div class="mt-2 mt-sm-0">
                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-sm btn-outline-primary active" data-chart="bookings">
                                    <i class="fas fa-calendar"></i> Bookings
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-primary" data-chart="members">
                                    <i class="fas fa-user-plus"></i> Members
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-primary" data-chart="both">
                                    <i class="fas fa-chart-line"></i> Both
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="chart-container">
                        <canvas id="dashboardChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity Section (Optional) -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="recent-card">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-clock me-2 text-primary"></i>
                        Recent Bookings
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var booking in Model.RecentBookings)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0">@booking.CustomerName</h6>
                                    <small class="text-muted">@booking.CheckInDate.ToString("MMM dd") - @booking.CheckOutDate.ToString("MMM dd, yyyy")</small>
                                </div>
                                <span class="badge bg-success rounded-pill">@booking.TotalAmount.ToString("C2")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="recent-card">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-users me-2 text-primary"></i>
                        Recent Members
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var user in Model.RecentUsers)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0">@user.FullName</h6>
                                    <small class="text-muted">Joined @user.JoinDate.ToString("MMM dd, yyyy")</small>
                                </div>
                                <i class="fas fa-user-check text-success"></i>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <script src="~/js/admin-dashboard.js"></script>
    
    <script>
        const chartData = @Html.Raw(Json.Serialize(Model.ChartData));
        
        document.addEventListener('DOMContentLoaded', function() {
        initializeDashboardChart(chartData);
            
        document.querySelectorAll('[data-chart]').forEach(btn => {
        btn.addEventListener('click', function() {
        document.querySelectorAll('[data-chart]').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const type = this.getAttribute('data-chart');
        updateChartType(type);
        });
        });
        });
    </script>
}