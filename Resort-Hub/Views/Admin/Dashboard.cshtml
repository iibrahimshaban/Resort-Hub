@using System.Globalization
@model Resort_Hub.ViewModels.Admin.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
    var egCulture = new CultureInfo("en-EG");
    egCulture.NumberFormat.CurrencySymbol = "EGP";
    egCulture.NumberFormat.CurrencyDecimalDigits = 2;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-dashboard.css" />
}


<div class="dashboard-wrapper">
    <!-- Modern Header with Gradient -->
    <div class="dashboard-header-modern">
        <div class="container-fluid">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <div class="header-content">
                        <div class="welcome-badge">
                            <i class="fas fa-chart-pie"></i>
                            <span>Analytics Dashboard</span>
                        </div>
                        <h1 class="dashboard-title">Welcome back, Admin</h1>
                        <p class="dashboard-subtitle">Here's what's happening with your resort business today.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="date-time-widget d-flex justify-content-center">
                        <i class="fas fa-calendar-alt me-2"></i>
                        <span id="currentDateTime" class="mx-2"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <div class="kpi-grid">
            <div class="kpi-card booking-card">
                <div class="kpi-card-inner">
                    <div class="kpi-icon-wrapper">
                        <div class="kpi-icon">
                            <i class="fas fa-calendar-check"></i>
                        </div>
                    </div>
                    <div class="kpi-content">
                        <p class="kpi-label">Total Bookings</p>
                        <h2 class="kpi-value">@Model.TotalBookings.ToString("N0")</h2>
                        <div class="kpi-trend @(Model.BookingsChange >= 0 ? "trend-up" : "trend-down")">
                            <i class="fas @(Model.BookingsChange >= 0 ? "fa-arrow-up" : "fa-arrow-down")"></i>
                            <span>@Math.Abs(Model.BookingsChange).ToString("N0") vs last month</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total Users Card -->
            <div class="kpi-card users-card">
                <div class="kpi-card-inner">
                    <div class="kpi-icon-wrapper">
                        <div class="kpi-icon">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                    <div class="kpi-content">
                        <p class="kpi-label">Total Users</p>
                        <h2 class="kpi-value">@Model.TotalUsers.ToString()</h2>
                        <div class="kpi-trend @(Model.UsersChange >= 0 ? "trend-up" : "trend-down")">
                            <i class="fas @(Model.UsersChange >= 0 ? "fa-arrow-up" : "fa-arrow-down")"></i>
                            <span>@Math.Abs(Model.UsersChange).ToString("N0") vs last month</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total Revenue Card -->
            <div class="kpi-card revenue-card">
                <div class="kpi-card-inner">
                    <div class="kpi-icon-wrapper">
                        <div class="kpi-icon">
                            <i class="fas fa-dollar-sign"></i>
                        </div>
                    </div>
                    <div class="kpi-content">
                        <p class="kpi-label">Total Revenue</p>
                        <h2 class="kpi-value">@Math.Abs(Model.TotalRevenue).ToString("C2", egCulture)</h2>
                        <div class="kpi-trend @(Model.RevenueChange >= 0 ? "trend-up" : "trend-down")">
                            <i class="fas @(Model.RevenueChange >= 0 ? "fa-arrow-up" : "fa-arrow-down")"></i>
                            <span>@Math.Abs(Model.RevenueChange).ToString("C2", egCulture) vs last month</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Average Booking Value Card -->
            <div class="kpi-card avg-card">
                <div class="kpi-card-inner">
                    <div class="kpi-icon-wrapper">
                        <div class="kpi-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                    </div>
                    <div class="kpi-content">
                        <p class="kpi-label">Avg. Booking Value</p>
                        <h2 class="kpi-value">@Math.Abs(Model.AverageBookingValue).ToString("C2", egCulture)</h2>
                        <div class="kpi-trend">
                            <i class="fas fa-calendar-week"></i>
                            <span>Last 30 days</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts and Analytics Row -->
        <div class="row g-4 mt-2">
            <div class="col-lg-8">
                <div class="chart-card-modern">
                    <div class="chart-card-header">
                        <div>
                            <h5 class="chart-title">
                                <i class="fas fa-chart-line me-2"></i>
                                Booking & Member Analytics
                            </h5>
                            <p class="chart-subtitle">Daily trends over the past 30 days</p>
                        </div>
                    </div>
                    <div class="chart-card-body">
                        <div class="chart-container-modern">
                            <canvas id="dashboardChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <!-- Quick Stats Widget -->
                <div class="quick-stats-card">
                    <div class="quick-stats-header">
                        <h5 class="stats-title">
                            <i class="fas fa-bolt me-2"></i>
                            Quick Stats
                        </h5>
                    </div>
                    <div class="quick-stats-body">
                        <div class="stat-item">
                            <div class="stat-info">
                                <span class="stat-name">Active Bookings</span>
                                <span class="stat-number">@Model.ActiveBookings.ToString("N0")</span>
                            </div>
                            <div class="progress-bar-modern">
                                @{
                                    var activePercentage = Model.TotalBookings > 0 ? (double)Model.ActiveBookings / Model.TotalBookings * 100 : 0;
                                }
                                <div class="progress-fill" style="width: @activePercentage%"></div>
                            </div>
                        </div>
        
                        <div class="stat-item">
                            <div class="stat-info">
                                <span class="stat-name">Occupancy Rate</span>
                                <span class="stat-number">@Model.OccupancyRate.ToString("F1")%</span>
                            </div>
                            <div class="progress-bar-modern">
                                <div class="progress-fill" style="width: @Model.OccupancyRate%"></div>
                            </div>
                        </div>
        
                        <div class="stat-item">
                            <div class="stat-info">
                                <span class="stat-name">Total Villas</span>
                                <span class="stat-number">@Model.TotalVillas.ToString("N0")</span>
                            </div>
                            <div class="progress-bar-modern">
                                @{
                                    var availableVillasPercentage = Model.TotalVillas > 0 ? (double)(Model.TotalVillas - Model.ActiveBookings) / Model.TotalVillas * 100 : 100;
                                }
                                <div class="progress-fill" style="width: @availableVillasPercentage%; background: linear-gradient(90deg, #1cc88a, #2ecc71);"></div>
                            </div>
                        </div>
        
                        <div class="stat-divider"></div>
        
                        <div class="stat-summary">
                            <div class="summary-item">
                                <i class="fas fa-building"></i>
                                <span>@Model.TotalVillas.ToString("N0") Properties</span>
                            </div>
                            <div class="summary-item">
                                <i class="fas fa-star"></i>
                                <span>@Model.AverageRating.ToString("F1") Rating</span>
                            </div>
                            <div class="summary-item">
                                <i class="fas fa-calendar-check"></i>
                                <span>@Model.TotalBookings.ToString("N0") Bookings</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity Section -->
        <div class="row g-4 mt-2">
            <div class="col-md-6">
                <div class="activity-card">
                    <div class="activity-card-header">
                        <h5 class="activity-title">
                            <i class="fas fa-clock me-2"></i>
                            Recent Bookings
                        </h5>
                        <a href="#" class="view-all-link">View All <i class="fas fa-arrow-right"></i></a>
                    </div>
                    <div class="activity-card-body">
                        @foreach (var booking in Model.RecentBookings.Take(5))
                        {
                            <div class="booking-item">
                                <div class="booking-avatar">
                                    <i class="fas fa-user-check"></i>
                                </div>
                                <div class="booking-details">
                                    <h6 class="booking-customer">@booking.UserFullName</h6>
                                    <p class="booking-date">
                                        <i class="fas fa-calendar-alt"></i>
                                        @booking.CheckInDate.ToString("MMM dd") - @booking.CheckOutDate.ToString("MMM dd, yyyy")
                                    </p>
                                </div>
                                <div class="booking-amount">
                                    <span class="amount">@booking.TotalCost.ToString("C2", egCulture)</span>
                                    <span class="status-badge status-confirmed">@booking.Status</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="activity-card">
                    <div class="activity-card-header">
                        <h5 class="activity-title">
                            <i class="fas fa-user-plus me-2"></i>
                            Recent Members
                        </h5>
                        <a href="#" class="view-all-link">View All <i class="fas fa-arrow-right"></i></a>
                    </div>
                    <div class="activity-card-body">
                        @foreach (var user in Model.RecentUsers.Take(5))
                        {
                            <div class="member-item">
                                <div class="member-avatar">
                                    <div class="avatar-circle">
                                        <span>@(user.FullName.Substring(0, 1))</span>
                                    </div>
                                </div>
                                <div class="member-details">
                                    <h6 class="member-name">@user.FullName</h6>
                                    <p class="member-email">
                                        <i class="fas fa-envelope"></i>
                                        @user.Email
                                    </p>
                                </div>
                                <div class="member-join-date">
                                    <i class="fas fa-calendar-plus"></i>
                                    <span>@user.JoinDate.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <script src="~/js/admin-dashboard.js"></script>
    
    <script>
        const chartData = @Html.Raw(Json.Serialize(Model.ChartData));
        
        function updateDateTime() {
        const now = new Date();
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
        const dateTimeElement = document.getElementById('currentDateTime');
        if (dateTimeElement) {
        dateTimeElement.textContent = now.toLocaleDateString('en-US', options);
        }
        }
        
        updateDateTime();
        setInterval(updateDateTime, 60000);
        
        document.addEventListener('DOMContentLoaded', function() {
        if (typeof initializeDashboardChart === 'function') {
        initializeDashboardChart(chartData);
        }
            
        document.querySelectorAll('.chart-toggle-btn').forEach(btn => {
        btn.addEventListener('click', function() {
        document.querySelectorAll('.chart-toggle-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const type = this.getAttribute('data-chart');
        if (typeof updateChartType === 'function') {
        updateChartType(type);
        }
        });
        });
        });
    </script>
}




