@using System.Globalization
@model Resort_Hub.ViewModels.Admin.UserListViewModel
@{
    ViewData["Title"] = "User Management";
    Layout = "_AdminLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-users.css" />
}

<div class="users-page">
    <div class="page-header">
        <div class="header-left">
            <h2><i class="fas fa-users"></i> User Management</h2>
            <p class="text-muted">Manage and monitor all registered users</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="filters-card">
        <form method="get" class="filters-form">
            <div class="filter-group">
                <i class="fas fa-search"></i>
                <input type="text" name="search" placeholder="Search by name or email..." value="@Model.SearchTerm" />
            </div>
            <div class="filter-group">
                <select name="role">
                    <option value="">All Roles</option>
                    <option value="Admin" selected="@(Model.RoleFilter == "Admin")">Admin</option>
                    <option value="User" selected="@(Model.RoleFilter == "User")">User</option>
                </select>
            </div>
            <button type="submit" class="btn-filter">Apply Filters</button>
            <a href="/Admin/Users" class="btn-reset">Reset</a>
        </form>
    </div>

    <!-- Users Table -->
    <div class="users-table-container">
        <table class="users-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Joined Date</th>
                    <th>Bookings</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar">
                                    <span>@user.AvatarInitial</span>
                                </div>
                                <div>
                                    <div class="user-name">@user.FullName</div>
                                </div>
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td>@(user.PhoneNumber ?? "Not provided")</td>
                        <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>@user.BookingsCount.ToString("N0")</td>
                        <td>
                            <div class="role-badge @(user.Roles.Contains("Admin") ? "role-admin" : "role-user")">
                                @(user.Roles.Contains("Admin") ? "Admin" : "User")
                            </div>
                        </td>
                       
                        <td>
                            <div class="action-buttons">
                                <button class="btn-icon view-btn" onclick="viewUser('@user.Id')" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="btn-icon edit-btn" onclick="editUser('@user.Id')" title="Edit Role">
                                    <i class="fas fa-edit"></i>
                                </button>
                               
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalCount > Model.PageSize)
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Showing @(((Model.CurrentPage - 1) * Model.PageSize) + 1) to @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)) of @Model.TotalCount users
            </div>
            <div class="pagination">
                @if (Model.CurrentPage > 1)
                {
                    <a href="?page=@(Model.CurrentPage - 1)&search=@Model.SearchTerm&role=@Model.RoleFilter" class="page-link">
                        <i class="fas fa-chevron-left"></i> Previous
                    </a>
                }
                @for (int i = 1; i <= Math.Ceiling((double)Model.TotalCount / Model.PageSize); i++)
                {
                    <a href="?page=@i&search=@Model.SearchTerm&role=@Model.RoleFilter" class="page-link @(i == Model.CurrentPage ? "active" : "")">@i</a>
                }
                @if (Model.CurrentPage < Math.Ceiling((double)Model.TotalCount / Model.PageSize))
                {
                    <a href="?page=@(Model.CurrentPage + 1)&search=@Model.SearchTerm&role=@Model.RoleFilter" class="page-link">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </div>
        </div>
    }
</div>

<!-- User Details Modal -->
<div class="modal" id="userDetailsModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>User Details</h3>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body" id="userDetails">
        </div>
    </div>
</div>



@section Scripts {
    <script src="~/js/admin-users.js"></script>
}