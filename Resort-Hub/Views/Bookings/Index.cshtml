@model Resort_Hub.ViewModels.Admin.BookingListViewModel
@{
    ViewData["Title"] = "Bookings Management";
    Layout = "_AdminLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-bookings.css" />
}

<div class="bookings-page">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-left">
            <h2><i class="fas fa-calendar-check"></i> Bookings Management</h2>
            <p class="text-muted">Manage and track all villa bookings</p>
        </div>
        <div class="header-right">
            <div class="status-stats">
                <span class="stat-badge pending">Pending: @Model.Bookings.Count(b => b.Status == Resort_Hub.Abstraction.Enums.VillaStatus.Pending)</span>
                <span class="stat-badge approved">Approved: @Model.Bookings.Count(b => b.Status == Resort_Hub.Abstraction.Enums.VillaStatus.Approved)</span>
                <span class="stat-badge checkedin">Checked-In: @Model.Bookings.Count(b => b.Status == Resort_Hub.Abstraction.Enums.VillaStatus.CheckedIn)</span>
                <span class="stat-badge completed">Completed: @Model.Bookings.Count(b => b.Status == Resort_Hub.Abstraction.Enums.VillaStatus.Completed)</span>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="filters-card">
        <form method="get" class="filters-form">
            <div class="filter-group">
                <i class="fas fa-search"></i>
                <input type="text" name="search" placeholder="Search by customer, email, or villa..." value="@Model.SearchTerm" />
            </div>
            <div class="filter-group">
                <select name="status" class=" px-3" >
                    <option value="">All Statuses</option>
                    <option value="0" selected="@(Model.StatusFilter == Resort_Hub.Abstraction.Enums.VillaStatus.Pending)">Pending</option>
                    <option value="1" selected="@(Model.StatusFilter == Resort_Hub.Abstraction.Enums.VillaStatus.Approved)">Approved</option>
                    <option value="2" selected="@(Model.StatusFilter == Resort_Hub.Abstraction.Enums.VillaStatus.CheckedIn)">Checked-In</option>
                    <option value="3" selected="@(Model.StatusFilter == Resort_Hub.Abstraction.Enums.VillaStatus.Completed)">Completed</option>
                    <option value="4" selected="@(Model.StatusFilter == Resort_Hub.Abstraction.Enums.VillaStatus.Cancelled)">Cancelled</option>
                </select>
            </div>
            <button type="submit" class="btn-filter">Apply Filters</button>
            <a href="/Admin/Bookings" class="btn-reset">Reset</a>
        </form>
    </div>

    <!-- Bookings Table -->
    <div class="bookings-table-container">
        <table class="bookings-table">
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Villa</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Nights</th>
                    <th>Total Cost</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model.Bookings)
                {
                    <tr>
                        <td>
                            <div class="customer-info">
                                <div class="customer-avatar">
                                    <span>@(booking.UserFullName.Substring(0, 1))</span>
                                </div>
                                <div>
                                    <div class="customer-name">@booking.UserFullName</div>
                                    <div class="customer-email">@booking.UserEmail</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="villa-info">
                                <img src="@booking.VillaImageUrl" alt="@booking.VillaName" class="villa-thumb" />
                                <span>@booking.VillaName</span>
                            </div>
                        </td>
                        <td>@booking.CheckInDate.ToString("MMM dd, yyyy")</td>
                        <td>@booking.CheckOutDate.ToString("MMM dd, yyyy")</td>
                        <td>@booking.Nights</td>
                        <td>@booking.TotalCost.ToString("C2")</td>
                        <td>
                            <span class="status-badge @booking.StatusBadgeClass">@booking.StatusDisplay</span>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn-icon view-btn" onclick="viewBooking(@booking.Id)">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <div class="status-dropdown">
                                    <button class="btn-icon status-btn" onclick="toggleStatusDropdown(@booking.Id)">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <div class="dropdown-menu" id="statusDropdown-@booking.Id">
                                        <a href="#" onclick="updateStatus(@booking.Id, 0)">Pending</a>
                                        <a href="#" onclick="updateStatus(@booking.Id, 1)">Approved</a>
                                        <a href="#" onclick="updateStatus(@booking.Id, 2)">Checked-In</a>
                                        <a href="#" onclick="updateStatus(@booking.Id, 3)">Completed</a>
                                        <a href="#" onclick="updateStatus(@booking.Id, 4)">Cancelled</a>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalCount > Model.PageSize)
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Showing @(((Model.CurrentPage - 1) * Model.PageSize) + 1) to @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)) of @Model.TotalCount bookings
            </div>
            <div class="pagination">
                @if (Model.CurrentPage > 1)
                {
                    <a href="?page=@(Model.CurrentPage - 1)&search=@Model.SearchTerm&status=@Model.StatusFilter" class="page-link">
                        <i class="fas fa-chevron-left"></i> Previous
                    </a>
                }
                @for (int i = 1; i <= Math.Ceiling((double)Model.TotalCount / Model.PageSize); i++)
                {
                    <a href="?page=@i&search=@Model.SearchTerm&status=@Model.StatusFilter" class="page-link @(i == Model.CurrentPage ? "active" : "")">@i</a>
                }
                @if (Model.CurrentPage < Math.Ceiling((double)Model.TotalCount / Model.PageSize))
                {
                    <a href="?page=@(Model.CurrentPage + 1)&search=@Model.SearchTerm&status=@Model.StatusFilter" class="page-link">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </div>
        </div>
    }
</div>

<!-- View Booking Modal -->
<div class="modal" id="viewBookingModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Booking Details</h3>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body" id="bookingDetails">
            <!-- Dynamic content -->
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-bookings.js"></script>
}