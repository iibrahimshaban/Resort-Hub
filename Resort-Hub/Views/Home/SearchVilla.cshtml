@using Resort_Hub.ViewModels.Home
@model List<VillaVM>
@{
    ViewData["Title"] = "All Villas";
    bool hasFilters = ViewBag.HasFilters ?? false;
}

@section Styles {
<style>
    :root {
        --primary: #1B3FE4;
        --primary-dark: #1230b0;
        --accent: #F5A623;
        --dark: #0D1B2A;
        --gray: #6B7280;
        --light: #F8F9FF;
        --radius: 16px;
        --card-shadow: 0 4px 24px rgba(27,63,228,0.10);
    }

    /* ── PAGE HEADER ── */
    .page-header {
        background: linear-gradient(135deg, #0D1B2A 0%, #1B3FE4 100%);
        padding: 4rem 6rem 3rem;
        color: #fff;
        position: relative;
        overflow: hidden;
    }

    .page-header::before {
        content: '';
        position: absolute;
        top: -80px; right: -80px;
        width: 350px; height: 350px;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
    }

    .page-header::after {
        content: '';
        position: absolute;
        bottom: -60px; left: 200px;
        width: 200px; height: 200px;
        background: rgba(255,255,255,0.04);
        border-radius: 50%;
    }

    .page-header h1 {
        font-size: 2.4rem;
        font-weight: 700;
        margin-bottom: 0.4rem;
        position: relative;
    }

    .page-header p {
        opacity: 0.75;
        font-size: 0.95rem;
        position: relative;
    }

    /* ── SEARCH BAR ── */
    .filter-section {
        padding: 0 6rem;
        position: relative;
        z-index: 10;
        margin-top: -28px;
    }

    .search-bar {
        background: #fff;
        border-radius: var(--radius);
        box-shadow: 0 8px 40px rgba(27,63,228,0.15);
        display: grid;
        grid-template-columns: 1fr 1fr 1fr auto auto;
        align-items: stretch;
        overflow: hidden;
        border: 1px solid rgba(27,63,228,0.08);
    }

    .search-field {
        padding: 16px 22px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-right: 1px solid #E5E7EB;
    }

    .search-field i { color: var(--primary); font-size: 1rem; flex-shrink: 0; }

    .search-field label {
        display: block;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--gray);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 3px;
    }

    .search-field input,
    .search-field select {
        border: none;
        outline: none;
        font-family: 'Poppins', sans-serif;
        font-size: 0.88rem;
        color: var(--dark);
        background: transparent;
        width: 100%;
    }

    .search-btn {
        background: var(--primary);
        color: #fff;
        padding: 0 28px;
        border: none;
        cursor: pointer;
        font-family: 'Poppins', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: background 0.2s;
        white-space: nowrap;
    }

    .search-btn:hover { background: var(--primary-dark); }

    .clear-btn {
        background: #F3F4F6;
        color: var(--gray);
        padding: 0 20px;
        border: none;
        cursor: pointer;
        font-family: 'Poppins', sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: background 0.2s, color 0.2s;
        white-space: nowrap;
        text-decoration: none;
    }

    .clear-btn:hover { background: #E5E7EB; color: var(--dark); text-decoration: none; }

    /* ── RESULTS AREA ── */
    .results-section { padding: 3rem 6rem; }

    .results-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.8rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .results-count {
        font-size: 0.9rem;
        color: var(--gray);
    }

    .results-count strong { color: var(--dark); font-weight: 600; }

    .active-filters {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .filter-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(27,63,228,0.08);
        color: var(--primary);
        font-size: 0.78rem;
        font-weight: 500;
        padding: 4px 12px;
        border-radius: 100px;
    }

    /* ── VILLA GRID ── */
    .villa-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    /* ── VILLA CARD ── */
    .villa-card {
        background: #fff;
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: var(--card-shadow);
        transition: transform 0.3s, box-shadow 0.3s;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        opacity: 0;
        transform: translateY(20px);
    }

    .villa-card.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .villa-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 48px rgba(27,63,228,0.18);
        text-decoration: none;
        color: inherit;
    }

    .villa-card-img {
        position: relative;
        height: 210px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .villa-card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s;
    }

    .villa-card:hover .villa-card-img img { transform: scale(1.06); }

    .no-image {
        width: 100%; height: 100%;
        background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
    }

    .price-badge {
        position: absolute;
        top: 12px; right: 12px;
        background: var(--primary);
        color: #fff;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 4px 11px;
        border-radius: 100px;
    }

    .popular-badge {
        position: absolute;
        top: 12px; left: 12px;
        background: var(--accent);
        color: #fff;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .villa-card-body {
        padding: 18px 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .villa-card-body h3 {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 6px;
    }

    .villa-location {
        font-size: 0.8rem;
        color: var(--gray);
        display: flex;
        align-items: center;
        gap: 4px;
        margin-bottom: 10px;
    }

    .villa-location i { color: var(--primary); }

    .villa-desc {
        font-size: 0.83rem;
        color: var(--gray);
        line-height: 1.6;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 14px;
    }

    .villa-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 14px;
        border-top: 1px solid #F3F4F6;
    }

    .villa-meta {
        display: flex;
        gap: 14px;
    }

    .villa-meta span {
        font-size: 0.78rem;
        color: var(--gray);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .villa-meta i { color: var(--primary); }

    .btn-view {
        background: rgba(27,63,228,0.08);
        color: var(--primary);
        font-size: 0.8rem;
        font-weight: 600;
        padding: 6px 14px;
        border-radius: 100px;
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
        white-space: nowrap;
    }

    .btn-view:hover {
        background: var(--primary);
        color: #fff;
        text-decoration: none;
    }

    /* ── EMPTY STATE ── */
    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 5rem 2rem;
        color: var(--gray);
    }

    .empty-icon {
        width: 80px; height: 80px;
        background: var(--light);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 1.2rem;
        color: var(--primary);
        opacity: 0.6;
    }

    .empty-state h3 { font-size: 1.2rem; font-weight: 600; color: var(--dark); margin-bottom: 0.5rem; }
    .empty-state p  { font-size: 0.9rem; margin-bottom: 1.5rem; }

    /* ── RESPONSIVE ── */
    @@media (max-width: 1100px) {
        .page-header, .filter-section, .results-section { padding-left: 2rem; padding-right: 2rem; }
        .villa-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 768px) {
        .page-header { padding: 3rem 2rem 2.5rem; }
        .page-header h1 { font-size: 1.8rem; }
        .search-bar { grid-template-columns: 1fr; }
        .search-field { border-right: none; border-bottom: 1px solid #E5E7EB; }
        .search-btn, .clear-btn { justify-content: center; padding: 14px; }
        .villa-grid { grid-template-columns: 1fr; }
    }
</style>
}

<!-- ══════════════════════════════════════
     PAGE HEADER
══════════════════════════════════════ -->
<div class="page-header">
    <h1>
        @if (hasFilters)
        {
            <span>Search Results</span>
        }
        else
        {
            <span>All Villas</span>
        }
    </h1>
    <p>
        @if (hasFilters)
        {
            <span>Showing villas matching your criteria</span>
        }
        else
        {
            <span>Explore our full collection of hand-picked villas</span>
        }
    </p>
</div>

<!-- ══════════════════════════════════════
     FILTER BAR
══════════════════════════════════════ -->
<div class="filter-section">
    <form asp-controller="Home" asp-action="SearchVilla" method="get">
        <div class="search-bar">
            <div class="search-field">
                <i class="bi bi-calendar3"></i>
                <div style="flex:1">
                    <label>Check In</label>
                    <input type="date" name="checkInDate"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")"
                           value="@ViewBag.CheckInDate" />
                </div>
            </div>
            <div class="search-field">
                <i class="bi bi-people"></i>
                <div style="flex:1">
                    <label>Guests</label>
                    <select name="personCount">
                        <option value="">Any</option>
                        @for (int i = 1; i <= 10; i++)
                        {
                            <option value="@i"
                                    selected="@(ViewBag.PersonCount?.ToString() == i.ToString() ? "selected" : null)">
                                @i Person@(i > 1 ? "s" : "")
                            </option>
                        }
                    </select>
                </div>
            </div>
            <div class="search-field">
                <i class="bi bi-geo-alt"></i>
                <div style="flex:1">
                    <label>Location</label>
                    <input type="text" name="location" placeholder="Where are you going?"
                           value="@ViewBag.Location" />
                </div>
            </div>
            <button type="submit" class="search-btn">
                <i class="bi bi-search"></i> Search
            </button>
            @if (hasFilters)
            {
                <a asp-controller="Home" asp-action="SearchVilla" class="clear-btn">
                    <i class="bi bi-x-circle"></i> Clear
                </a>
            }
        </div>
    </form>
</div>

<!-- ══════════════════════════════════════
     RESULTS
══════════════════════════════════════ -->
<section class="results-section">
    <div class="results-meta">
        <p class="results-count">
            Showing <strong>@Model.Count villa@(Model.Count != 1 ? "s" : "")</strong>
            @if (hasFilters) { <span>matching your search</span> }
        </p>

        @if (hasFilters)
        {
            <div class="active-filters">
                @if (!string.IsNullOrEmpty(ViewBag.CheckInDate?.ToString()))
                {
                    <span class="filter-tag">
                        <i class="bi bi-calendar3"></i> @ViewBag.CheckInDate
                    </span>
                }
                @if (ViewBag.PersonCount != null)
                {
                    <span class="filter-tag">
                        <i class="bi bi-people"></i> @ViewBag.PersonCount Person@(ViewBag.PersonCount > 1 ? "s" : "")
                    </span>
                }
                @if (!string.IsNullOrEmpty(ViewBag.Location?.ToString()))
                {
                    <span class="filter-tag">
                        <i class="bi bi-geo-alt"></i> @ViewBag.Location
                    </span>
                }
            </div>
        }
    </div>

    <div class="villa-grid">
        @if (Model.Any())
        {
            @foreach (var villa in Model)
            {
                <a asp-controller="Villa" asp-action="Info"
                   asp-route-id="@villa.Id" class="villa-card">
                    <div class="villa-card-img">
                        @if (!string.IsNullOrEmpty(villa.MainImageUrl))
                        {
                            <img src="@villa.MainImageUrl" alt="@villa.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="no-image">🏡</div>
                        }
                        <div class="price-badge">$@villa.PricePerNight.ToString("0")/night</div>
                        @if (villa.IsPopularChoice)
                        {
                            <div class="popular-badge">⭐ Popular</div>
                        }
                    </div>
                    <div class="villa-card-body">
                        <h3>@villa.Name</h3>
                        @if (!string.IsNullOrEmpty(villa.Location))
                        {
                            <div class="villa-location">
                                <i class="bi bi-geo-alt-fill"></i> @villa.Location
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(villa.Description))
                        {
                            <p class="villa-desc">@villa.Description</p>
                        }
                        <div class="villa-card-footer">
                            <div class="villa-meta">
                                <span><i class="bi bi-people"></i> Up to @villa.Capacity</span>
                                <span>
                                    <i class="bi bi-circle-fill"
                                       style="color: @(villa.IsAvailable ? "#22c55e" : "#ef4444"); font-size:0.5rem"></i>
                                    @(villa.IsAvailable ? "Available" : "Unavailable")
                                </span>
                            </div>
                            <span class="btn-view">View Details</span>
                        </div>
                    </div>
                </a>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-house-slash"></i></div>
                <h3>No villas found</h3>
                <p>Try adjusting your search filters to find the perfect villa.</p>
                <a asp-controller="Home" asp-action="SearchVilla"
                   class="btn btn-primary rounded-pill px-4">
                    Clear Filters
                </a>
            </div>
        }
    </div>
</section>

@section Scripts {
<script>
    // Staggered card reveal on load
    const cards = document.querySelectorAll('.villa-card');
    cards.forEach((card, i) => {
        card.style.transition = `opacity 0.4s ease ${i * 0.06}s, transform 0.4s ease ${i * 0.06}s`;
        setTimeout(() => card.classList.add('visible'), 50);
    });
</script>
}
