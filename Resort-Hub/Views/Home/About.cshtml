@{
    ViewData["Title"] = "About";
}

@section Styles {
<style>
    :root {
        --primary: #1B3FE4;
        --primary-dark: #1230b0;
        --accent: #F5A623;
        --dark: #0D1B2A;
        --gray: #6B7280;
        --light: #F8F9FF;
        --radius: 16px;
    }

    /* ── PAGE HEADER ── */
    .page-header {
        background: linear-gradient(135deg, #0D1B2A 0%, #1B3FE4 100%);
        padding: 5rem 6rem 4rem;
        color: #fff;
        position: relative;
        overflow: hidden;
        text-align: center;
    }

    .page-header::before {
        content: '';
        position: absolute;
        top: -80px; right: -80px;
        width: 350px; height: 350px;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
    }

    .page-header::after {
        content: '';
        position: absolute;
        bottom: -60px; left: 150px;
        width: 200px; height: 200px;
        background: rgba(255,255,255,0.04);
        border-radius: 50%;
    }

    .page-header h1 {
        font-size: 2.8rem;
        font-weight: 700;
        margin-bottom: 0.8rem;
        position: relative;
    }

    .page-header p {
        opacity: 0.75;
        font-size: 1rem;
        max-width: 500px;
        margin: 0 auto;
        position: relative;
        line-height: 1.7;
    }

    /* ── SECTIONS ── */
    .about-section { padding: 5rem 6rem; }
    .about-section.bg-light-blue { background: var(--light); }

    /* ── MISSION ── */
    .mission-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .mission-img {
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(27,63,228,0.15);
        height: 400px;
        background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 5rem;
    }

    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(27,63,228,0.08);
        color: var(--primary);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 5px 14px;
        border-radius: 100px;
        margin-bottom: 1rem;
    }

    .section-heading {
        font-size: 2rem;
        font-weight: 700;
        color: var(--dark);
        line-height: 1.2;
        margin-bottom: 1rem;
    }

    .section-heading span { color: var(--primary); }

    .section-text {
        font-size: 0.95rem;
        color: var(--gray);
        line-height: 1.8;
        margin-bottom: 1rem;
    }

    /* ── STATS ── */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        text-align: center;
        padding: 4rem 6rem;
        background: var(--primary);
        color: #fff;
    }

    .stat-number {
        font-size: 2.5rem;
        font-weight: 700;
        display: block;
        line-height: 1;
        margin-bottom: 0.4rem;
    }

    .stat-label {
        font-size: 0.82rem;
        opacity: 0.8;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    /* ── VALUES ── */
    .values-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .value-card {
        background: #fff;
        border-radius: var(--radius);
        padding: 2rem;
        box-shadow: 0 4px 24px rgba(27,63,228,0.08);
        transition: transform 0.3s, box-shadow 0.3s;
        opacity: 0;
        transform: translateY(20px);
    }

    .value-card.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .value-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px rgba(27,63,228,0.15);
    }

    .value-icon {
        width: 52px; height: 52px;
        background: rgba(27,63,228,0.08);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 1.2rem;
        color: var(--primary);
    }

    .value-card h3 {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 0.6rem;
    }

    .value-card p {
        font-size: 0.88rem;
        color: var(--gray);
        line-height: 1.7;
        margin: 0;
    }

    /* ── TEAM ── */
    .team-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .team-card {
        text-align: center;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.4s ease, transform 0.4s ease;
    }

    .team-card.visible { opacity: 1; transform: translateY(0); }

    .team-avatar {
        width: 90px; height: 90px;
        border-radius: 50%;
        background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 1rem;
        box-shadow: 0 4px 16px rgba(27,63,228,0.15);
    }

    .team-card h4 {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 3px;
    }

    .team-card span {
        font-size: 0.78rem;
        color: var(--primary);
        font-weight: 500;
    }

    /* ── RESPONSIVE ── */
    @@media (max-width: 1100px) {
        .page-header, .about-section { padding-left: 2rem; padding-right: 2rem; }
        .stats-row { padding: 3rem 2rem; grid-template-columns: repeat(2, 1fr); }
        .values-grid { grid-template-columns: repeat(2, 1fr); }
        .team-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 768px) {
        .page-header { padding: 3rem 2rem; }
        .page-header h1 { font-size: 2rem; }
        .mission-grid { grid-template-columns: 1fr; }
        .mission-img { height: 260px; }
        .values-grid, .team-grid { grid-template-columns: 1fr; }
        .stats-row { grid-template-columns: repeat(2, 1fr); }
    }
</style>
}

<!-- ══════════════════════════════════════
     PAGE HEADER
══════════════════════════════════════ -->
<div class="page-header">
    <h1>About <span style="color: rgba(255,255,255,0.7)">Resort</span>Hub.</h1>
    <p>We're on a mission to make every vacation unforgettable — one villa at a time.</p>
</div>

<!-- ══════════════════════════════════════
     MISSION
══════════════════════════════════════ -->
<section class="about-section">
    <div class="mission-grid">
        <div class="mission-img">🏝️</div>
        <div>
            <div class="section-label"><i class="bi bi-stars"></i> Our Mission</div>
            <h2 class="section-heading">We Make Your <span>Dream Vacation</span> A Reality</h2>
            <p class="section-text">
                ResortHub was founded with a simple belief: everyone deserves a perfect getaway.
                We connect travelers with hand-picked villas and resorts across the world,
                making the booking experience seamless, transparent, and enjoyable.
            </p>
            <p class="section-text">
                From cozy beachfront cottages to luxurious hilltop estates, every property
                on our platform is carefully verified to meet our quality standards — so you
                can book with complete confidence.
            </p>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════
     STATS
══════════════════════════════════════ -->
<div class="stats-row">
    <div>
        <span class="stat-number">2,500+</span>
        <span class="stat-label">Happy Guests</span>
    </div>
    <div>
        <span class="stat-number">200+</span>
        <span class="stat-label">Properties</span>
    </div>
    <div>
        <span class="stat-number">100+</span>
        <span class="stat-label">Villas</span>
    </div>
    <div>
        <span class="stat-number">4.9★</span>
        <span class="stat-label">Average Rating</span>
    </div>
</div>

<!-- ══════════════════════════════════════
     VALUES
══════════════════════════════════════ -->
<section class="about-section bg-light-blue">
    <div style="text-align:center; margin-bottom: 2.5rem;">
        <div class="section-label" style="display:inline-flex"><i class="bi bi-heart"></i> Our Values</div>
        <h2 class="section-heading">What Drives <span>Everything We Do</span></h2>
    </div>

    <div class="values-grid">
        <div class="value-card">
            <div class="value-icon"><i class="bi bi-shield-check"></i></div>
            <h3>Trust & Transparency</h3>
            <p>Every listing is verified. No hidden fees, no surprises — just honest pricing and accurate descriptions you can count on.</p>
        </div>
        <div class="value-card">
            <div class="value-icon"><i class="bi bi-gem"></i></div>
            <h3>Quality First</h3>
            <p>We hand-pick every property on our platform. If it doesn't meet our standards, it doesn't make the cut — simple as that.</p>
        </div>
        <div class="value-card">
            <div class="value-icon"><i class="bi bi-headset"></i></div>
            <h3>Guest Support</h3>
            <p>Our team is available around the clock. Whether it's a last-minute question or an on-site issue, we've got your back.</p>
        </div>
        <div class="value-card">
            <div class="value-icon"><i class="bi bi-globe2"></i></div>
            <h3>Global Reach</h3>
            <p>From tropical islands to mountain retreats, our network of properties spans destinations across the globe.</p>
        </div>
        <div class="value-card">
            <div class="value-icon"><i class="bi bi-lightning-charge"></i></div>
            <h3>Seamless Experience</h3>
            <p>From search to check-in, every step is designed to be fast, intuitive, and stress-free for both guests and owners.</p>
        </div>
        <div class="value-card">
            <div class="value-icon"><i class="bi bi-leaf"></i></div>
            <h3>Sustainability</h3>
            <p>We partner with eco-conscious properties and promote responsible tourism to protect the destinations we love.</p>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════
     TEAM
══════════════════════════════════════ -->
<section class="about-section">
    <div style="text-align:center; margin-bottom: 2.5rem;">
        <div class="section-label" style="display:inline-flex"><i class="bi bi-people"></i> Our Team</div>
        <h2 class="section-heading">The People Behind <span>ResortHub</span></h2>
    </div>

    <div class="team-grid">
        <div class="team-card">
            <div class="team-avatar">👨‍💼</div>
            <h4>Salman Faris</h4>
            <span>Founder & CEO</span>
        </div>
        <div class="team-card">
            <div class="team-avatar">👩‍💻</div>
            <h4>Sara Ahmed</h4>
            <span>Head of Product</span>
        </div>
        <div class="team-card">
            <div class="team-avatar">👨‍🎨</div>
            <h4>Omar Khalid</h4>
            <span>Lead Designer</span>
        </div>
        <div class="team-card">
            <div class="team-avatar">👩‍🔧</div>
            <h4>Nour Hassan</h4>
            <span>Engineering Lead</span>
        </div>
    </div>
</section>

@section Scripts {
<script>
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.value-card, .team-card').forEach((el, i) => {
        el.style.transitionDelay = `${i * 0.07}s`;
        observer.observe(el);
    });
</script>
}
