@model Resort_Hub.ViewModels.Auth.ForgotPasswordVM

@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password – Resort Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
    <link href="~/css/Login.css" rel="stylesheet" />
</head>
<body>

    <div class="auth-card">
        <div class="panel-image">
            <div class="brand">Resort<span>Hub</span>.</div>
        </div>

        <div class="panel-form">
            <div class="form-inner">

                <div style="text-align:center; margin-bottom:1.5rem;">
                    <div style="width:56px; height:56px; background:#eef1ff; border-radius:50%;
                        display:flex; align-items:center; justify-content:center; margin:0 auto 1rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none"
                             viewBox="0 0 24 24" stroke="#4f8ef7" stroke-width="1.8">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </div>
                    <h1 style="margin-bottom:0.4rem;">Forgot password?</h1>
                    <p style="font-size:0.875rem; color:#888; margin:0;">
                        Enter your email and we'll send you a reset code
                    </p>
                </div>

                <form asp-action="ForgotPassword" asp-controller="Auth" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="field-group">
                        <label asp-for="Email">Email address</label>
                        <input asp-for="Email" placeholder="name@gmail.com" type="text" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-login">Send reset code</button>
                </form>

                <p class="register-link" style="margin-top:1.25rem;">
                    <a asp-action="Login" asp-controller="Auth"
                           style="color:#4f8ef7; text-decoration:none; font-size:0.875rem;">
                        ← Back to login
                    </a>
                </p>

            </div>
        </div>
    </div>

    <partial name="_ErrorPopUp" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>