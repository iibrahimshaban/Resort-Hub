@model Resort_Hub.ViewModels.Auth.LoginVM

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – Resort Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
    <link href="~/css/Login.css" rel="stylesheet" />
</head>
<body>

    <div class="auth-card ">
        <!-- Left: image -->
        <div class="panel-image">
            <div class="brand">Resort<span>Hub</span>.</div>
        </div>

        <!-- Right: form -->
        <div class="panel-form">
            <div class="form-inner">

                <a asp-action="Index" asp-controller="Home"
                       style="display:inline-flex;align-items:center;gap:6px;font-size:0.85rem;
                    color:#4f8ef7;text-decoration:none;margin-bottom:1.25rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                    Back to Home
                </a>

                <h1>Login Account</h1>

                <form asp-action="Login" asp-controller="Auth" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="field-group">
                        <label asp-for="Email">Username</label>
                        <input type="text" asp-for="Email" placeholder="Username" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="field-group">
                        <div class="d-flex justify-content-between align-items-center">
                            <label asp-for="Password">Password</label>
                            <a asp-action="ForgotPassword" asp-controller="Auth"
                               style="font-size:0.8rem; color:#4f8ef7; text-decoration:none;">Forgot password?</a>
                        </div>
                        <div class="pass-wrap">
                            <input asp-for="Password" type="password" placeholder="6+ characters" id="pwd" />
                            <button type="button" class="pass-toggle" onclick="togglePass('pwd', this)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="remember-row">
                        <input asp-for="RememberMe" id="rememberMe" />
                        <label for="rememberMe">Remember me</label>
                    </div>

                    <button type="submit" class="btn-login">Login</button>
                </form>

                <div class="divider">
                    <span>or continue with</span>
                </div>

                <a asp-action="ExternalLogin" asp-controller="Auth" class="btn-google">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48">
                        <path fill="#EA4335" d="M24 9.5c3.14 0 5.95 1.08 8.17 2.85l6.1-6.1C34.36 3.08 29.45 1 24 1 14.82 1 7.07 6.48 3.58 14.18l7.1 5.52C12.4 13.62 17.74 9.5 24 9.5z" />
                        <path fill="#4285F4" d="M46.52 24.5c0-1.64-.15-3.22-.42-4.74H24v8.98h12.67c-.55 2.94-2.2 5.43-4.68 7.1l7.18 5.58C43.44 37.64 46.52 31.5 46.52 24.5z" />
                        <path fill="#FBBC05" d="M10.68 28.3A14.6 14.6 0 0 1 9.5 24c0-1.49.26-2.93.68-4.3l-7.1-5.52A23.93 23.93 0 0 0 0 24c0 3.86.92 7.5 2.56 10.72l8.12-6.42z" />
                        <path fill="#34A853" d="M24 47c5.45 0 10.02-1.8 13.36-4.88l-7.18-5.58c-1.8 1.2-4.1 1.96-6.18 1.96-6.26 0-11.6-4.12-13.32-9.7l-8.12 6.42C7.07 41.52 14.82 47 24 47z" />
                    </svg>
                    Continue with Google
                </a>

                <p class="register-link">
                    Don't have an account? <a asp-action="Register" asp-controller="Auth">Create Account</a>
                </p>
            </div>
        </div>
    </div>

    <partial name="_ErrorPopUp" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

    <script>
        @if (TempData["ClearHistory"] != null)
        {
            <text>location.replace(window.location.href);</text>
        }

        function togglePass(id, btn) {
            const input = document.getElementById(id);
            input.type = input.type === 'password' ? 'text' : 'password';
            btn.style.color = input.type === 'text' ? '#4f8ef7' : '#aaa';
        }
    </script>
</body>
</html>