@model Resort_Hub.ViewModels.Auth.ResetPasswordVM

@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
    bool otpVerified = !string.IsNullOrEmpty(Model.Otp);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password – Resort Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
    <link href="~/css/Login.css" rel="stylesheet" />
</head>
<body>
    <div class="auth-card">
        <div class="panel-image">
            <div class="brand">Resort<span>Hub</span>.</div>
        </div>

    <div class="panel-form">
        <div class="form-inner">

            <div style="text-align:center; margin-bottom:1.5rem;">
                <div style="width:56px;height:56px;background:#eef1ff;border-radius:50%;
                    display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none"
                         viewBox="0 0 24 24" stroke="#4f8ef7" stroke-width="1.8">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                    </svg>
                </div>
                <h1 style="margin-bottom:0.4rem;">Reset password</h1>
                <p style="font-size:0.875rem;color:#888;margin:0;">
                    @if (otpVerified)
                    {
                        <span>Set a new password for <strong>@Model.Email</strong></span>
                    }
                    else
                    {
                        <span>Enter the code sent to <strong>@Model.Email</strong></span>
                    }
                </p>
            </div>

            @* ── STEP 1: OTP form ── *@
            @if (!otpVerified)
            {
                <form asp-action="VerifyResetOtp" asp-controller="Auth" method="post">
                    <input type="hidden" name="email" value="@Model.Email" />

                    <div class="field-group">
                        <label asp-for="Otp">Reset code</label>
                        <input asp-for="Otp" placeholder="000000" maxlength="6"
                               style="text-align:center;font-size:1.6rem;letter-spacing:10px;
                        font-weight:700;padding:0.6rem 1rem;"
                               oninput="document.getElementById('verifyBtn').disabled = this.value.length < 6" />
                        <span asp-validation-for="Otp" class="text-danger"></span>
                    </div>

                    <button type="submit" id="verifyBtn" class="btn-login"
                            style="margin-top:0.5rem;" disabled>
                        Verify code
                    </button>
                </form>
            }

            @* ── STEP 2: Password form (only after OTP verified) ── *@
            @if (otpVerified)
            {
                <div style="text-align:center;margin-bottom:1.25rem;">
                    <div style="display:inline-flex;align-items:center;gap:.4rem;
                        background:#ecfdf5;border:1px solid #6ee7b7;
                        border-radius:8px;padding:.5rem 1rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none"
                             viewBox="0 0 24 24" stroke="#059669" stroke-width="2">
                            <polyline points="20 6 9 17 4 12" />
                        </svg>
                        <span style="font-size:.85rem;color:#065f46;font-weight:500;">Code verified</span>
                    </div>
                </div>

                <form asp-action="ResetPassword" asp-controller="Auth" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Otp" />

                    <div class="field-group">
                        <label asp-for="NewPassword">New password</label>
                        <div class="pass-wrap">
                            <input asp-for="NewPassword" type="password"
                                   placeholder="6+ characters" id="pwd" />
                            <button type="button" class="pass-toggle" onclick="togglePass('pwd',this)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="ConfirmPassword">Confirm new password</label>
                        <div class="pass-wrap">
                            <input asp-for="ConfirmPassword" type="password"
                                   placeholder="Repeat password" id="cpwd" />
                            <button type="button" class="pass-toggle" onclick="togglePass('cpwd',this)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-login">Reset password</button>
                </form>
            }

        </div>
    </div>
    </div>

    <partial name="_ErrorPopUp" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

    <script>
        function togglePass(id, btn) {
        const input = document.getElementById(id);
        input.type = input.type === 'password' ? 'text' : 'password';
        btn.style.color = input.type === 'text' ? '#4f8ef7' : '#aaa';
        }
    </script>
</body>
</html>