@model Resort_Hub.ViewModels.Auth.ConfirmEmailVM

@{
    ViewData["Title"] = "Confirm Email";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Confirm Email – Resort Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
    <link href="~/css/Login.css" rel="stylesheet" />
</head>
<body>

    <div class="auth-card">
        <div class="panel-image">
            <div class="brand">Resort<span>Hub</span>.</div>
        </div>

        <div class="panel-form">
            <div class="form-inner">

                <a asp-action="Index" asp-controller="Home"
                       style="display:inline-flex;align-items:center;gap:6px;font-size:0.85rem;
                    color:#4f8ef7;text-decoration:none;margin-bottom:1.25rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                    Back to Home
                </a>

                <div style="text-align:center; margin-bottom:1.5rem;">
                    <div style="width:56px; height:56px; background:#eef1ff; border-radius:50%;
                        display:flex; align-items:center; justify-content:center; margin:0 auto 1rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none"
                             viewBox="0 0 24 24" stroke="#4f8ef7" stroke-width="1.8">
                            <path d="M4 4h16v16H4z" rx="2" />
                            <polyline points="22,6 12,13 2,6" />
                        </svg>
                    </div>
                    <h1 style="margin-bottom:0.4rem;">Check your email</h1>
                    <p style="font-size:0.875rem; color:#888; margin:0;">
                        We sent a 6-digit code to <strong>@Model.Email</strong>
                    </p>
                </div>

                @if (TempData["Info"] is string info)
                {
                    <div style="background:#eef1ff; border:1px solid #c7d2fe; border-radius:10px;
                        padding:0.75rem 1rem; margin-bottom:1.25rem;
                        display:flex; align-items:center; gap:10px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                             viewBox="0 0 24 24" stroke="#4f8ef7" stroke-width="1.8" style="flex-shrink:0;">
                            <path d="M4 4h16v16H4z" />
                            <polyline points="22,6 12,13 2,6" />
                        </svg>
                        <span style="font-size:0.875rem; color:#3730a3;">@info</span>
                    </div>
                }

                <form asp-action="ConfirmEmail" asp-controller="Auth" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Email" />

                    <div class="field-group">
                        <label asp-for="Code">Verification code</label>
                        <input asp-for="Code"
                               placeholder="000000"
                               maxlength="6"
                               style="text-align:center; font-size:1.6rem; letter-spacing:10px;
                        font-weight:700; padding: 0.6rem 1rem;" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-login" style="margin-top:0.5rem;">
                        Verify email
                    </button>
                </form>

                <form asp-action="ResendConfirmation" asp-controller="Auth"
                      method="post" style="text-align:center; margin-top:1.25rem;">
                    <input type="hidden" name="email" value="@Model.Email" />
                    <p style="font-size:0.85rem; color:#888; margin-bottom:0.5rem;">
                        Didn't receive the code?
                    </p>
                    <button type="submit" id="resendBtn"
                            style="background:none; border:1px solid #ddd; border-radius:8px;
                        padding:0.4rem 1.25rem; font-size:0.85rem; color:#555;
                        cursor:pointer; transition: border-color 0.2s, color 0.2s;"
                            onclick="handleResend(this)">
                        Resend code
                    </button>
                </form>

            </div>
        </div>
    </div>

    <partial name="_ErrorPopUp" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

    <script>
        function handleResend(btn) {
        btn.disabled = true;
        btn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
        viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
        style="animation:spin 1s linear infinite; margin-right:6px; vertical-align:middle;">
        <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
        Sending...
        `;
        btn.style.color = '#4f8ef7';
        btn.style.borderColor = '#4f8ef7';

        setTimeout(() => {
        btn.disabled = false;
        btn.innerHTML = 'Resend code';
        btn.style.color = '';
        btn.style.borderColor = '';
        }, 2000);  // ← inside the function
        }
    </script>
</body>
</html>