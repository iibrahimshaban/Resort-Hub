<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Admin Custom CSS -->
    <link rel="stylesheet" href="~/css/admin-layout.css" />
    <link rel="stylesheet" href="~/css/admin-dashboard.css" />
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="admin-app">
        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fas fa-hotel"></i>
                    <span>Resort Hub</span>
                </div>
                <span class="sidebar-badge">Admin Panel</span>
            </div>
            
            <nav class="sidebar-nav">
                <a href="/Admin/Dashboard" class="nav-link active">
                    <i class="fas fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/Admin/Bookings" class="nav-link">
                    <i class="fas fa-calendar-check"></i>
                    <span>Bookings</span>
                </a>
                <a href="/Admin/Users" class="nav-link">
                    <i class="fas fa-users"></i>
                    <span>Users</span>
                </a>
                <a href="/Admin/Villas" class="nav-link">
                    <i class="fas fa-building"></i>
                    <span>Villas</span>
                </a>
                <a href="/Admin/Amenities" class="nav-link">
                    <i class="fas fa-spa"></i>
                    <span>Amenities</span>
                </a>
                <a href="/Admin/Reports" class="nav-link">
                    <i class="fas fa-chart-bar"></i>
                    <span>Reports</span>
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <a href="/" class="nav-link">
                    <i class="fas fa-globe"></i>
                    <span>View Website</span>
                </a>
                <a href="/Account/Logout" class="nav-link">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="admin-main">
            <!-- Top Navigation Bar -->
            <div class="admin-topbar">
                <div class="topbar-left">
                    <button class="sidebar-toggle" id="sidebarToggle">
                        <i class="fas fa-bars"></i>
                    </button>
                    <div class="page-title">
                        <h1>@ViewData["Title"]</h1>
                    </div>
                </div>
                
                <div class="topbar-right">
                   
                    
   
                    
                    <div class="admin-profile">
                        <div class="profile-info">
                            <span class="profile-name">Admin User</span>
                            <span class="profile-role">Administrator</span>
                        </div>
                        <div class="profile-avatar">
                            <i class="fas fa-user-circle"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Page Content -->
            <div class="admin-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin-layout.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>