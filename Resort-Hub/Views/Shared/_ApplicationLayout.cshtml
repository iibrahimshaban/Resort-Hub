@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Resort Hub</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/AdvancedLayout.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ── NAVBAR ── -->
    <nav class="ls-navbar">
        <div class="container d-flex align-items-center justify-content-between">

            <a class="navbar-brand ls-brand" asp-area="" asp-controller="Home" asp-action="Index">
                Resort<span>Hub</span>.
            </a>

            <ul class="nav d-none d-md-flex align-items-center mb-0">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Hotels" asp-action="Index">Hotels</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Rooms" asp-action="Index">Rooms</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                </li>
            </ul>

            <div class="d-flex align-items-center gap-3">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                   var currentUser = await UserManager.GetUserAsync(User);
                   var initials = $"{currentUser?.FirstName?.FirstOrDefault()}{currentUser?.LastName?.FirstOrDefault()}".ToUpper();
                    
                    <!-- Avatar button → opens profile modal -->
                    <button class="btn p-0 border-0 ls-avatar-btn"
                            data-bs-toggle="modal"
                            data-bs-target="#profileModal"
                            title="My Profile">
                        @if (!string.IsNullOrEmpty(currentUser?.ProfilePictureUrl))
                        {
                            <img src="@currentUser.ProfilePictureUrl"
                                 class="ls-avatar-img" alt="avatar" />
                        }
                        else
                        {
                            <span class="ls-avatar-initials">@initials</span>
                        }
                    </button>

                    <!-- Logout -->
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                        <button type="submit" class="btn-login">Logout</button>
                    </form>
                }
                else
                {
                    <a class="btn-login" asp-controller="Auth" asp-action="Login">Login</a>
                }

                <button class="btn d-md-none p-0 border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mobileNav">
                    <i class="bi bi-list fs-4"></i>
                </button>
            </div>
        </div>

        <!-- mobile menu -->
        <div class="collapse container" id="mobileNav">
            <ul class="nav flex-column py-2">
                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Hotels" asp-action="Index">Hotels</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Rooms" asp-action="Index">Rooms</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a></li>
            </ul>
        </div>
    </nav>

    <!-- ── PAGE CONTENT ── -->
    <main>
        @RenderBody()
    </main>

    <!-- ── FOOTER ── -->
    <footer>
        <div class="ls-footer-upper">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-start gap-4">
                <div>
                    <div class="ls-brand ls-footer-brand">Resort<span>Hub</span>.</div>
                    <p>We kaboom your beauty holiday<br />instantly and memorable.</p>
                </div>
                <div class="ls-footer-cta text-md-end">
                    <h6>Become hotel Owner</h6>
                    <a asp-controller="Auth" asp-action="Register" class="btn-register">Register Now</a>
                </div>
            </div>
        </div>
        <div class="ls-footer-bottom">
            <p>Copyright 2024 &bull; All rights reserved &bull; Salman Faris</p>
        </div>
    </footer>

    <!-- ── MODALS ── -->
    <partial name="_ErrorPopUp" />
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <partial name="_ProfileModal" />
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.getElementById('profilePictureInput')?.addEventListener('change', function () {
        const file = this.files[0];
        if (!file) return;
        const preview = document.getElementById('avatarPreview');
        const initials = document.getElementById('avatarInitials');
        preview.src = URL.createObjectURL(file);
        preview.classList.remove('d-none');
        initials?.classList.add('d-none');
        });
    </script>
    <script>
        (function () {
        let cropper = null;
        const cropperModalEl = document.getElementById('cropperModal');
        const profileModalEl = document.getElementById('profileModal');
        if (!cropperModalEl) return;

        const cropperModal  = new bootstrap.Modal(cropperModalEl);
        const profileModal  = bootstrap.Modal.getInstance(profileModalEl)
        ?? new bootstrap.Modal(profileModalEl);
        const cropperImage  = document.getElementById('cropperImage');
        const fileInput     = document.getElementById('profilePictureInput');

        // ── 1. File picked → open cropper ──────────────────────
        fileInput?.addEventListener('change', function () {
        const file = this.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = (e) => {
        // hide profile modal, show cropper
        profileModal.hide();
        cropperImage.src = e.target.result;
        cropperModal.show();
        };
        reader.readAsDataURL(file);
        this.value = ''; // reset so same file can be re-picked
        });

        // ── 2. Init Cropper.js once modal is shown ──────────────
        cropperModalEl.addEventListener('shown.bs.modal', function () {
        cropper = new Cropper(cropperImage, {
        aspectRatio: 1,          // default 1:1 for avatars
        viewMode: 1,
        autoCropArea: 0.8,
        movable: true,
        zoomable: true,
        scalable: false,
        preview: '.crop-preview'
        });
        });

        // ── 3. Destroy cropper when modal closes ────────────────
        cropperModalEl.addEventListener('hidden.bs.modal', function () {
        cropper?.destroy();
        cropper = null;
        });

        // ── 4. Aspect ratio buttons ─────────────────────────────
        document.getElementById('ratio11')?.addEventListener('click', () => cropper?.setAspectRatio(1));
        document.getElementById('ratio43')?.addEventListener('click', () => cropper?.setAspectRatio(4/3));
        document.getElementById('ratioFree')?.addEventListener('click', () => cropper?.setAspectRatio(NaN));

        // ── 5. Cancel → go back to profile modal ───────────────
        document.getElementById('cancelCrop')?.addEventListener('click', function () {
        cropperModal.hide();
        cropperModalEl.addEventListener('hidden.bs.modal', function reopen() {
        profileModal.show();
        cropperModalEl.removeEventListener('hidden.bs.modal', reopen);
        });
        });

        // ── 6. Confirm crop → upload via fetch ─────────────────
        document.getElementById('confirmCrop')?.addEventListener('click', async function () {
        if (!cropper) return;

        const btn = this;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Uploading...';

        // get cropped canvas → blob
        const canvas = cropper.getCroppedCanvas({ width: 400, height: 400 });
        canvas.toBlob(async (blob) => {
        const formData = new FormData();
        formData.append('Picture', blob, 'avatar.jpg');

        // grab antiforgery token from the profile form
        const token = document.querySelector('#profileModal input[name="__RequestVerificationToken"]')?.value;
        if (token) formData.append('__RequestVerificationToken', token);

        try {
        const response = await fetch('/Account/UpdateProfilePicture', {
        method: 'POST',
        body: formData,
        headers: { 'RequestVerificationToken': token ?? '' }
        });

        if (response.ok || response.redirected) {
        // update the avatar preview in navbar + modal without full reload
        const objectUrl = URL.createObjectURL(blob);

        const navAvatar = document.querySelector('.ls-avatar-img');
        const navInitials = document.querySelector('.ls-avatar-initials');
        if (navAvatar) {
        navAvatar.src = objectUrl;
        } else if (navInitials) {
        // swap initials for real image
        const img = document.createElement('img');
        img.src = objectUrl;
        img.className = 'ls-avatar-img';
        navInitials.replaceWith(img);
        }

        const modalAvatar = document.getElementById('avatarPreview');
        const modalInitials = document.getElementById('avatarInitials');
        if (modalAvatar) {
        modalAvatar.src = objectUrl;
        modalAvatar.classList.remove('d-none');
        }
        modalInitials?.classList.add('d-none');

        cropperModal.hide();
        cropperModalEl.addEventListener('hidden.bs.modal', function reopen() {
        profileModal.show();
        cropperModalEl.removeEventListener('hidden.bs.modal', reopen);
        });
        }
        } catch (err) {
        console.error('Upload failed', err);
        } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check2 me-1"></i>Crop & Upload';
        }
        }, 'image/jpeg', 0.92);
        });
        })();
    </script>

</body>
</html>