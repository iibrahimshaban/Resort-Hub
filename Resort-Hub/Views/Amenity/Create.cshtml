@model Resort_Hub.Entities.Amenity

@{
    ViewData["Title"] = "Add Amenity";
    Layout = "_AdminLayout";
}

<section class="py-5">
    <div class="container" style="max-width:520px;">

        <div class="mb-4">
            <a asp-action="Index" class="text-decoration-none small"
                   style="color:#003DFC;">
                <i class="bi bi-arrow-left me-1"></i>Back to Amenities
            </a>
            <h2 class="fw-700 mt-2 mb-0" style="font-family:'Plus Jakarta Sans',sans-serif;">Add Amenity</h2>
        </div>

        <div class="card border-0" style="border-radius:16px;box-shadow:0 2px 16px rgba(0,61,252,.08);">
            <div class="card-body p-4">

                <!-- Icon preview header -->
                <div class="text-center mb-4">
                    <div id="icon-circle"
                         style="width:72px;height:72px;background:#f0f3ff;border-radius:50%;
                        display:flex;align-items:center;justify-content:center;
                        margin:0 auto 10px;border:2px solid #dce3ff;">
                        <i id="icon-preview" class="bi bi-tag-fill" style="font-size:1.8rem;color:#003DFC;"></i>
                    </div>
                    <div class="small text-muted">Icon preview</div>
                </div>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-600 small">
                            Amenity Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control"
                               style="border-radius:10px;border-color:#dce3ff;border-width:1.5px;"
                               placeholder="e.g. Swimming Pool" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-600 small">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  style="border-radius:10px;border-color:#dce3ff;border-width:1.5px;resize:none;"
                                  placeholder="Brief description..."></textarea>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Icon" class="form-label fw-600 small">
                            Icon
                        </label>
                        <div class="position-relative">
                            <input asp-for="Icon"
                                   id="icon-input"
                                   class="form-control"
                                   autocomplete="off"
                                   placeholder="Search Font Awesome icon (e.g. user, car, home)..." />

                            <div id="icon-results"
                                 class="shadow bg-white border rounded mt-1 p-2"
                                 style="display:none;position:absolute;z-index:1000;width:100%;max-height:300px;overflow:auto;">
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill py-2"
                           style="border-radius:12px;">Cancel</a>
                        <button type="submit" class="btn text-white flex-fill py-2 fw-600"
                                style="background:#3252DF;border-radius:12px;border:none;
                            font-family:'Plus Jakarta Sans',sans-serif;">
                            <i class="bi bi-plus-lg me-2"></i>Add Amenity
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin-amenity.js" type="module"></script>
}