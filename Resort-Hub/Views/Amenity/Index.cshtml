@model IEnumerable<Resort_Hub.Entities.Amenity>

@{
    ViewData["Title"] = "Amenities";
    Layout = "_AdminLayout";
}

<section class="py-5">
    <div class="container">

        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h2 class="fw-700 mb-1" style="font-family:'Plus Jakarta Sans',sans-serif;">Amenities</h2>
                <p class="text-muted mb-0">Manage available amenities for villas</p>
            </div>
            <a asp-action="Create" class="btn fw-600 text-white px-4 py-2"
                   style="background:#3252DF;border-radius:12px;border:none;font-family:'Plus Jakarta Sans',sans-serif;">
                <i class="bi bi-plus-lg me-2"></i>Add Amenity
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-dismissible fade show border-0 rounded-3 text-white" role="alert"
                 style="background:#3252DF;">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 my-5">
                <div style="width:80px;height:80px;background:#f0f3ff;border-radius:50%;
                    display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                    <i class="bi bi-stars" style="font-size:2rem;color:#3252DF;"></i>
                </div>
                <h5 class="fw-700 mb-2" style="font-family:'Plus Jakarta Sans',sans-serif;">No amenities yet</h5>
                <p class="text-muted mb-4">Add amenities to assign them to villas.</p>
                <a asp-action="Create" class="btn text-white fw-600 px-4"
                       style="background:#3252DF;border-radius:12px;border:none;">
                    <i class="bi bi-plus-lg me-2"></i>Add Amenity
                </a>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var amenity in Model)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card border-0 h-100"
                             style="border-radius:14px;box-shadow:0 2px 12px rgba(0,0,0,.07);
                            transition:transform .2s,box-shadow .2s;"
                             onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 24px rgba(0,61,252,.12)'"
                             onmouseleave="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 12px rgba(0,0,0,.07)'">
                            <div class="card-body p-4 d-flex align-items-start gap-3">

                                <!-- Icon box -->
                                <div style="width:48px;height:48px;background:#f0f3ff;border-radius:12px;
                                    display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                    @if (!string.IsNullOrEmpty(amenity.Icon))
                                    {
                                        <i class="@amenity.Icon" style="font-size:1.4rem;color:#003DFC;"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-tag-fill" style="font-size:1.4rem;color:#003DFC;"></i>
                                    }
                                </div>

                                <!-- Info -->
                                <div class="flex-grow-1">
                                    <div class="fw-700 mb-1" style="font-family:'Plus Jakarta Sans',sans-serif;font-size:15px;">
                                        @amenity.Name
                                    </div>
                                    @if (!string.IsNullOrEmpty(amenity.Description))
                                    {
                                        <div class="small text-muted" style="line-height:1.5;">@amenity.Description</div>
                                    }
                                    else
                                    {
                                        <div class="small" style="color:#c0c0c0;">No description</div>
                                    }
                                </div>

                                <!-- Actions -->
                                <div class="d-flex flex-column gap-2">
                                    <a asp-action="Edit" asp-route-id="@amenity.Id"
                                           class="btn btn-sm text-white"
                                           style="background:#003DFC;border-radius:8px;border:none;
                                        width:32px;height:32px;padding:0;
                                        display:flex;align-items:center;justify-content:center;">
                                        <i class="bi bi-pencil" style="font-size:13px;"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@amenity.Id" method="post"
                                          onsubmit="return confirm('Delete @amenity.Name?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                style="background:transparent;border:1px solid #fca5a5;border-radius:8px;
                                            width:32px;height:32px;padding:0;cursor:pointer;
                                            display:flex;align-items:center;justify-content:center;color:#dc2626;">
                                            <i class="bi bi-trash" style="font-size:13px;"></i>
                                        </button>
                                    </form>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>

            <p class="text-muted small mt-3">
                <i class="bi bi-stars me-1" style="color:#003DFC;"></i>
                @Model.Count() amenit@(Model.Count() == 1 ? "y" : "ies") total
            </p>
        }

    </div>
</section>