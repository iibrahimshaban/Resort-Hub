@model IEnumerable<Resort_Hub.Entities.Amenity>

@{
    ViewData["Title"] = "Amenities";
    Layout = "_ApplicationLayout";
}

<section class="py-5">
    <div class="container">

        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h2 class="fw-700 mb-1" style="font-family:'Plus Jakarta Sans',sans-serif;">Amenities</h2>
                <p class="text-muted mb-0">Manage available amenities for villas</p>
            </div>
            <a asp-action="Create" class="btn btn-dark px-4 py-2 fw-600" style="border-radius:12px;font-family:'Plus Jakarta Sans',sans-serif;">
                <i class="bi bi-plus-lg me-2"></i>Add Amenity
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 rounded-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-stars" style="font-size:4rem;color:#ddd;"></i>
                <h5 class="mt-3 fw-600" style="font-family:'Plus Jakarta Sans',sans-serif;">No amenities yet</h5>
                <p class="text-muted">Add amenities to assign them to villas.</p>
                <a asp-action="Create" class="btn btn-dark px-4" style="border-radius:12px;">Add Amenity</a>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm" style="border-radius:16px;overflow:hidden;">
                <table class="table table-hover mb-0">
                    <thead style="background:#f9fafb;border-bottom:1px solid #f3f4f6;">
                        <tr>
                            <th class="fw-600 px-4 py-3 small" style="font-family:'Plus Jakarta Sans',sans-serif;">Icon</th>
                            <th class="fw-600 px-4 py-3 small" style="font-family:'Plus Jakarta Sans',sans-serif;">Name</th>
                            <th class="fw-600 px-4 py-3 small d-none d-md-table-cell" style="font-family:'Plus Jakarta Sans',sans-serif;">Description</th>
                            <th class="fw-600 px-4 py-3 small text-end" style="font-family:'Plus Jakarta Sans',sans-serif;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var amenity in Model)
                        {
                            <tr style="border-bottom:1px solid #f9fafb;">
                                <td class="px-4 py-3 align-middle">
                                    @if (!string.IsNullOrEmpty(amenity.Icon))
                                    {
                                        <div style="width:36px;height:36px;border-radius:8px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;">
                                            <i class="@amenity.Icon text-muted"></i>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="width:36px;height:36px;border-radius:8px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;">
                                            <i class="bi bi-tag text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td class="px-4 py-3 align-middle fw-600" style="font-family:'Plus Jakarta Sans',sans-serif;">@amenity.Name</td>
                                <td class="px-4 py-3 align-middle text-muted small d-none d-md-table-cell">
                                    @(amenity.Description ?? "—")
                                </td>
                                <td class="px-4 py-3 align-middle text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Edit" asp-route-id="@amenity.Id"
                                               class="btn btn-sm btn-dark px-3" style="border-radius:8px;">
                                            <i class="bi bi-pencil me-1"></i>Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@amenity.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Delete @amenity.Name?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-3" style="border-radius:8px;">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <p class="text-muted small mt-2">@Model.Count() amenit@(Model.Count() == 1 ? "y" : "ies") total</p>
        }

    </div>
</section>
