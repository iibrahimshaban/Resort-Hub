@model IEnumerable<Resort_Hub.Entities.Villa>

@{
    ViewData["Title"] = "Villas";
    Layout = "_AdminLayout";
}

<section class="py-5">
    <div class="container">

        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h2 class="fw-700 mb-1" style="font-family:'Plus Jakarta Sans',sans-serif;">Villas</h2>
                <p class="text-muted mb-0">Manage all villas in the system</p>
            </div>
            <a asp-action="Create" class="btn fw-600 text-white px-4 py-2"
                   style="background:#3252DF;border-radius:12px;border:none;font-family:'Plus Jakarta Sans',sans-serif;">
                <i class="bi bi-plus-lg me-2"></i>Add Villa
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-dismissible fade show border-0 rounded-3 text-white" role="alert"
                 style="background:#3252DF;">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 my-5">
                <div style="width:80px;height:80px;background:#f0f3ff;border-radius:50%;
                    display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                    <i class="bi bi-house-door" style="font-size:2rem;color:#3252DF;"></i>
                </div>
                <h5 class="fw-700 mb-2" style="font-family:'Plus Jakarta Sans',sans-serif;">No villas yet</h5>
                <p class="text-muted mb-4">Start by adding your first villa.</p>
                <a asp-action="Create" class="btn text-white fw-600 px-4"
                       style="background:#3252DF;border-radius:12px;border:none;">
                    <i class="bi bi-plus-lg me-2"></i>Add Villa
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var villa in Model)
                {
                    var mainImage = villa.VillaImages?.FirstOrDefault(i => i.IsMain)
                                 ?? villa.VillaImages?.OrderBy(i => i.DispalayOrder).FirstOrDefault();

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card border-0 h-100"
                             style="border-radius:16px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.08);
                            transition:transform .2s,box-shadow .2s;"
                             onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(0,61,252,.15)'"
                             onmouseleave="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 12px rgba(0,0,0,.08)'">

                            <!-- Image -->
                            <div style="position:relative;height:210px;overflow:hidden;background:#e8eeff;">
                                @if (mainImage != null)
                                {
                                    <img src="@mainImage.ImageUrl" alt="@villa.Name"
                                         style="width:100%;height:100%;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100">
                                        <i class="bi bi-image" style="font-size:3rem;color:#c7d2fe;"></i>
                                    </div>
                                }

                                <!-- Price badge -->
                                <div style="position:absolute;top:12px;right:12px;background:#3252DF;color:#fff;
                                    padding:5px 14px;border-radius:20px;font-size:13px;font-weight:700;
                                    font-family:'Plus Jakarta Sans',sans-serif;">
                                    $@villa.PricePerNight
                                    <span style="font-weight:400;font-size:11px;opacity:.9;"> per night</span>
                                </div>

                                <!-- Name overlay -->
                                <div style="position:absolute;bottom:0;left:0;right:0;
                                    background:linear-gradient(transparent,rgba(0,0,0,.75));
                                    padding:36px 14px 14px;">
                                    <div style="color:#fff;font-size:16px;font-weight:700;
                                        font-family:'Plus Jakarta Sans',sans-serif;line-height:1.3;">
                                        @villa.Name
                                    </div>
                                    <div style="color:rgba(255,255,255,.75);font-size:12px;margin-top:3px;">
                                        <i class="bi bi-geo-alt-fill me-1"></i>Resort Hub Property
                                    </div>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="card-body p-3 d-flex flex-column">

                                <!-- Stats -->
                                <div class="d-flex justify-content-between align-items-center mb-3 pb-3"
                                     style="border-bottom:1px solid #f0f3ff;">
                                    <span class="small text-muted">
                                        <i class="bi bi-people-fill me-1" style="color:#3252DF;"></i>@villa.Capacity guests
                                    </span>
                                    <span class="small text-muted">
                                        <i class="bi bi-aspect-ratio me-1" style="color:#3252DF;"></i>@villa.Sqft sqft
                                    </span>
                                    @if (villa.IsAvilable)
                                    {
                                        <span style="background:#e8f5e9;color:#2e7d32;font-size:11px;
                                        font-weight:600;padding:3px 10px;border-radius:20px;">Available</span>
                                    }
                                    else
                                    {
                                        <span style="background:#fce4ec;color:#c62828;font-size:11px;
                                        font-weight:600;padding:3px 10px;border-radius:20px;">Unavailable</span>
                                    }
                                </div>

                                <!-- Amenities pills -->
                                @if (villa.VillaAmenity?.Any() == true)
                                {
                                    <div class="d-flex flex-wrap gap-1 mb-3">
                                        @foreach (var va in villa.VillaAmenity.Take(3))
                                        {
                                            <span style="background:#f0f3ff;color:#3252DF;font-size:11px;
                                                font-weight:500;padding:3px 10px;border-radius:20px;">
                                                @if (!string.IsNullOrEmpty(va.Amenity?.Icon))
                                                {
                                                    <i class="@va.Amenity.Icon me-1"></i>
                                                }
                                                @va.Amenity?.Name
                                            </span>
                                        }
                                        @if (villa.VillaAmenity.Count > 3)
                                        {
                                            <span style="background:#f0f3ff;color:#3252DF;font-size:11px;
                                                font-weight:500;padding:3px 10px;border-radius:20px;">
                                                +@(villa.VillaAmenity.Count - 3) more
                                            </span>
                                        }
                                    </div>
                                }

                                <!-- Actions -->
                                <div class="d-flex gap-2 mt-auto">
                                    <a asp-action="Details" asp-route-id="@villa.Id"
                                           class="btn flex-fill fw-600 text-white"
                                           style="background:#3252DF;border-radius:10px;font-size:13px;border:none;">
                                        <i class="bi bi-eye me-1"></i>Details
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@villa.Id"
                                           class="btn btn-outline-secondary"
                                           style="border-radius:10px;font-size:13px;width:38px;padding:0;
                                        display:flex;align-items:center;justify-content:center;">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@villa.Id"
                                           class="btn btn-outline-danger"
                                           style="border-radius:10px;font-size:13px;width:38px;padding:0;
                                        display:flex;align-items:center;justify-content:center;">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</section>