@model IEnumerable<Resort_Hub.Entities.Villa>

@{
    ViewData["Title"] = "Villas";
    Layout = "_ApplicationLayout";
}

<section class="py-5">
    <div class="container">

        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h2 class="fw-700 mb-1" style="font-family:'Plus Jakarta Sans',sans-serif;">Villas</h2>
                <p class="text-muted mb-0">Manage all villas in the system</p>
            </div>
            <a asp-action="Create" class="btn btn-dark px-4 py-2 fw-600" style="border-radius:12px;font-family:'Plus Jakarta Sans',sans-serif;">
                <i class="bi bi-plus-lg me-2"></i>Add Villa
            </a>
        </div>

        <!-- Success / Error alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 rounded-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Empty state -->
        @if (!Model.Any())
        {
            <div class="text-center py-5 my-5">
                <i class="bi bi-house-door" style="font-size:4rem;color:#ddd;"></i>
                <h5 class="mt-3 fw-600" style="font-family:'Plus Jakarta Sans',sans-serif;">No villas yet</h5>
                <p class="text-muted">Start by adding your first villa.</p>
                <a asp-action="Create" class="btn btn-dark px-4" style="border-radius:12px;">Add Villa</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var villa in Model)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card border-0 shadow-sm h-100" style="border-radius:16px;overflow:hidden;transition:transform .2s;"
                             onmouseenter="this.style.transform='translateY(-4px)'"
                             onmouseleave="this.style.transform='translateY(0)'">

                            <!-- Villa image -->
                            @{
                                var mainImage = villa.VillaImages?.FirstOrDefault(i => i.IsMain)
                                             ?? villa.VillaImages?.OrderBy(i => i.DispalayOrder).FirstOrDefault();
                            }
                            <div style="height:200px;background:#f5f5f5;overflow:hidden;position:relative;">
                                @if (mainImage != null)
                                {
                                    <img src="@mainImage.ImageUrl" alt="@villa.Name"
                                         style="width:100%;height:100%;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100">
                                        <i class="bi bi-image text-muted" style="font-size:3rem;"></i>
                                    </div>
                                }
                                <!-- Status badge -->
                                <span class="badge position-absolute top-0 end-0 m-3 px-3 py-2"
                                      style="border-radius:20px;font-size:11px;font-family:'Plus Jakarta Sans',sans-serif;
                                    background:@(villa.IsAvilable ? "#d1fae5" : "#fee2e2");
                                    color:@(villa.IsAvilable ? "#065f46" : "#991b1b");">
                                    @(villa.IsAvilable ? "Available" : "Unavailable")
                                </span>
                            </div>

                            <div class="card-body p-4">
                                <h5 class="fw-700 mb-1" style="font-family:'Plus Jakarta Sans',sans-serif;">@villa.Name</h5>
                                <p class="text-muted small mb-3" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                    @(villa.Description ?? "No description provided.")
                                </p>

                                <!-- Stats row -->
                                <div class="d-flex gap-3 mb-3">
                                    <span class="small text-muted"><i class="bi bi-people me-1"></i>@villa.Capacity guests</span>
                                    <span class="small text-muted"><i class="bi bi-rulers me-1"></i>@villa.Sqft sqft</span>
                                </div>

                                <!-- Price -->
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <div>
                                        <span class="fw-700 fs-5" style="font-family:'Plus Jakarta Sans',sans-serif;">$@villa.PricePerNight</span>
                                        <span class="text-muted small"> / night</span>
                                    </div>
                                    @if (villa.VillaAmenity?.Any() == true)
                                    {
                                        <span class="small text-muted"><i class="bi bi-stars me-1"></i>@villa.VillaAmenity.Count amenities</span>
                                    }
                                </div>

                                <!-- Actions -->
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@villa.Id"
                                           class="btn btn-outline-secondary flex-fill" style="border-radius:10px;font-size:13px;">
                                        <i class="bi bi-eye me-1"></i>Details
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@villa.Id"
                                           class="btn btn-dark flex-fill" style="border-radius:10px;font-size:13px;">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@villa.Id"
                                           class="btn btn-outline-danger" style="border-radius:10px;font-size:13px;width:40px;padding:0;display:flex;align-items:center;justify-content:center;">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</section>
