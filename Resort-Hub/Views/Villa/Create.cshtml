@model Resort_Hub.ViewModels.Villa.VillaFormVM

@{
    ViewData["Title"] = "Add Villa";
    Layout = "_ApplicationLayout";
}

<section class="py-5">
    <div class="container" style="max-width:800px;">

        <div class="mb-4">
            <a asp-action="Index" class="text-decoration-none small" style="color:#3252DF;">
                <i class="bi bi-arrow-left me-1"></i>Back to Villas
            </a>
            <h2 class="fw-700 mt-2 mb-0" style="font-family:'Plus Jakarta Sans',sans-serif;">Add New Villa</h2>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row g-4">

                <!-- LEFT -->
                <div class="col-12 col-lg-8">

                    <div class="card border-0 mb-4"
                         style="border-radius:16px;box-shadow:0 2px 16px rgba(0,61,252,.08);">
                        <div class="card-body p-4">
                            <h6 class="fw-700 mb-4" style="font-family:'Plus Jakarta Sans',sans-serif;color:#3252DF;">
                                <i class="bi bi-house me-2"></i>Basic Information
                            </h6>

                            <div class="mb-3">
                                <label asp-for="Name" class="form-label fw-600 small">Villa Name <span class="text-danger">*</span></label>
                                <input asp-for="Name" class="form-control"
                                       style="border-radius:10px;border-color:#dce3ff;border-width:1.5px;"
                                       placeholder="e.g. Ocean Breeze Villa" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Description" class="form-label fw-600 small">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="4"
                                          style="border-radius:10px;border-color:#dce3ff;border-width:1.5px;resize:none;"
                                          placeholder="Describe the villa..."></textarea>
                            </div>

                            <div class="row g-3">
                                <div class="col-6">
                                    <label asp-for="PricePerNight" class="form-label fw-600 small">Price / Night ($) <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text"
                                              style="border-radius:10px 0 0 10px;border-color:#dce3ff;
                                        background:#f0f3ff;color:#3252DF;font-weight:600;">$</span>
                                        <input asp-for="PricePerNight" class="form-control" type="number" step="0.01"
                                               style="border-radius:0 10px 10px 0;border-color:#dce3ff;" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="PricePerNight" class="text-danger small"></span>
                                </div>
                                <div class="col-6">
                                    <label asp-for="Sqft" class="form-label fw-600 small">Area (sqft) <span class="text-danger">*</span></label>
                                    <input asp-for="Sqft" class="form-control" type="number"
                                           style="border-radius:10px;border-color:#dce3ff;border-width:1.5px;"
                                           placeholder="e.g. 1200" />
                                    <span asp-validation-for="Sqft" class="text-danger small"></span>
                                </div>
                                <div class="col-6">
                                    <label asp-for="Capacity" class="form-label fw-600 small">Capacity (guests) <span class="text-danger">*</span></label>
                                    <input asp-for="Capacity" class="form-control" type="number"
                                           style="border-radius:10px;border-color:#dce3ff;border-width:1.5px;"
                                           placeholder="e.g. 4" />
                                    <span asp-validation-for="Capacity" class="text-danger small"></span>
                                </div>
                                <div class="col-6 d-flex align-items-end">
                                    <div class="form-check form-switch mb-2">
                                        <input asp-for="IsAvilable" class="form-check-input" type="checkbox"
                                               role="switch" style="width:40px;height:22px;accent-color:#3252DF;" />
                                        <label asp-for="IsAvilable" class="form-check-label fw-600 ms-2 small">Available</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Images -->
                    <div class="card border-0 mb-4"
                         style="border-radius:16px;box-shadow:0 2px 16px rgba(0,61,252,.08);">
                        <div class="card-body p-4">
                            <h6 class="fw-700 mb-3" style="font-family:'Plus Jakarta Sans',sans-serif;color:#3252DF;">
                                <i class="bi bi-images me-2"></i>Villa Images
                            </h6>
                            <div onclick="document.getElementById('img-input').click()"
                                 style="border:2px dashed #dce3ff;border-radius:12px;padding:36px;
                                text-align:center;cursor:pointer;transition:border-color .2s,background .2s;"
                                 onmouseenter="this.style.borderColor='#003DFC';this.style.background='#f8f9ff'"
                                 onmouseleave="this.style.borderColor='#dce3ff';this.style.background='transparent'">
                                <div style="width:52px;height:52px;background:#f0f3ff;border-radius:50%;
                                    display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                                    <i class="bi bi-cloud-upload" style="font-size:1.5rem;color:#3252DF;"></i>
                                </div>
                                <div class="fw-600 mb-1" style="font-family:'Plus Jakarta Sans',sans-serif;">Click to upload images</div>
                                <div class="small text-muted">PNG, JPG up to 10MB. First image = main image.</div>
                            </div>
                            <input type="file" id="img-input" name="NewImages" multiple accept="image/*"
                                   class="d-none" onchange="previewImages(this)" />
                            <div id="img-preview" class="d-flex flex-wrap gap-2 mt-3"></div>
                        </div>
                    </div>

                </div>

                <!-- RIGHT -->
                <div class="col-12 col-lg-4">
                    <div class="card border-0 sticky-top"
                         style="border-radius:16px;box-shadow:0 2px 16px rgba(0,61,252,.08);top:20px;">
                        <div class="card-body p-4">
                            <h6 class="fw-700 mb-3" style="font-family:'Plus Jakarta Sans',sans-serif;color:#3252DF;">
                                <i class="bi bi-stars me-2"></i>Amenities
                            </h6>

                            @if (!Model.AvailableAmenities.Any())
                            {
                                <div class="text-center py-3">
                                    <i class="bi bi-stars text-muted" style="font-size:2rem;"></i>
                                    <p class="small text-muted mt-2 mb-0">
                                        No amenities yet.
                                        <a asp-controller="Amenity" asp-action="Create" style="color:#3252DF;">Add one</a>
                                    </p>
                                </div>
                            }
                            else
                            {
                                <div style="max-height:320px;overflow-y:auto;">
                                    @foreach (var amenity in Model.AvailableAmenities)
                                    {
                                        <div class="form-check mb-2 p-3 rounded-3"
                                             style="border:1.5px solid #f0f3ff;transition:all .15s;cursor:pointer;"
                                             onmouseenter="this.style.borderColor='#003DFC';this.style.background='#f8f9ff'"
                                             onmouseleave="this.style.borderColor='#f0f3ff';this.style.background='transparent'">
                                            <input class="form-check-input" type="checkbox"
                                                   name="SelectedAmenityIds" value="@amenity.Id"
                                                   id="amenity_@amenity.Id"
                                                   style="accent-color:#3252DF;" />
                                            <label class="form-check-label w-100" for="amenity_@amenity.Id"
                                                   style="cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;">
                                                @if (!string.IsNullOrEmpty(amenity.Icon))
                                                {
                                                    <i class="@amenity.Icon me-2" style="color:#3252DF;"></i>
                                                }
                                                <span class="fw-600">@amenity.Name</span>
                                                @if (!string.IsNullOrEmpty(amenity.Description))
                                                {
                                                    <br /><small class="text-muted ms-4">@amenity.Description</small>
                                                }
                                            </label>
                                        </div>
                                    }
                                </div>
                            }

                            <hr style="border-color:#f0f3ff;" class="my-3" />

                            <button type="submit" class="btn text-white w-100 py-2 fw-600"
                                    style="background:#3252DF;border-radius:12px;border:none;
                                font-family:'Plus Jakarta Sans',sans-serif;">
                                <i class="bi bi-plus-lg me-2"></i>Create Villa
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2 mt-2"
                               style="border-radius:12px;">Cancel</a>
                        </div>
                    </div>
                </div>

            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImages(input) {
            const preview = document.getElementById('img-preview');
            preview.innerHTML = '';
            Array.from(input.files).forEach((file, i) => {
                const reader = new FileReader();
                reader.onload = e => {
                    const wrap = document.createElement('div');
                    wrap.style.cssText = `position:relative;width:90px;height:90px;border-radius:10px;
                        overflow:hidden;border:2px solid ${i === 0 ? '#003DFC' : '#e5e7eb'}`;
                    wrap.innerHTML = `<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;">
                        ${i === 0 ? '<span style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,61,252,.8);color:#fff;font-size:10px;text-align:center;padding:2px;">Main</span>' : ''}`;
                    preview.appendChild(wrap);
                };
                reader.readAsDataURL(file);
            });
        }
    </script>
}