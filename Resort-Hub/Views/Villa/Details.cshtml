@model Resort_Hub.Entities.Villa

@{
    ViewData["Title"] = Model.Name;
    Layout = "_ApplicationLayout";
}

<section class="py-5">
    <div class="container" style="max-width:900px;">

        <div class="mb-4">
            <a asp-action="Index" class="text-decoration-none small" style="color:#3252DF;">
                <i class="bi bi-arrow-left me-1"></i>Back to Villas
            </a>
        </div>

        @{
            var images = Model.VillaImages?.OrderBy(i => i.DispalayOrder).ToList();
            var mainImg = images?.FirstOrDefault(i => i.IsMain) ?? images?.FirstOrDefault();
        }

        <div class="row g-4">

            <!-- Gallery -->
            <div class="col-12">
                <div class="card border-0" style="border-radius:16px;overflow:hidden;box-shadow:0 2px 16px rgba(0,61,252,.08);">
                    <div style="position:relative;height:360px;background:#e8eeff;">
                        @if (mainImg != null)
                        {
                            <img id="main-img" src="@mainImg.ImageUrl" alt="@Model.Name"
                                 style="width:100%;height:100%;object-fit:cover;transition:opacity .3s;" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100">
                                <i class="bi bi-image" style="font-size:4rem;color:#c7d2fe;"></i>
                            </div>
                        }

                        <!-- Price badge -->
                        <div style="position:absolute;top:16px;right:16px;background:#3252DF;color:#fff;
                            padding:8px 18px;border-radius:24px;font-size:15px;font-weight:700;
                            font-family:'Plus Jakarta Sans',sans-serif;">
                            $@Model.PricePerNight
                            <span style="font-weight:400;font-size:12px;opacity:.9;"> per night</span>
                        </div>

                        <!-- Name overlay -->
                        <div style="position:absolute;bottom:0;left:0;right:0;
                            background:linear-gradient(transparent,rgba(0,0,0,.75));
                            padding:48px 20px 20px;">
                            <div style="color:#fff;font-size:22px;font-weight:700;
                                font-family:'Plus Jakarta Sans',sans-serif;">
                                @Model.Name
                            </div>
                            <div style="color:rgba(255,255,255,.75);font-size:13px;margin-top:4px;">
                                <i class="bi bi-geo-alt-fill me-1"></i>Resort Hub Property
                            </div>
                        </div>
                    </div>

                    @if (images != null && images.Count > 1)
                    {
                        <div class="p-3 d-flex gap-2 flex-wrap" style="background:#fafbff;">
                            @foreach (var img in images)
                            {
                                <div onclick="switchImage('@img.ImageUrl', this)"
                                     style="width:72px;height:72px;border-radius:10px;overflow:hidden;cursor:pointer;
                                    border:2px solid @(img.IsMain ? "#003DFC" : "#e5e7eb");transition:border-color .2s;"
                                     onmouseenter="this.style.borderColor='#003DFC'"
                                     onmouseleave="this.style.borderColor='@(img.IsMain ? "#003DFC" : "#e5e7eb")'">
                                    <img src="@img.ImageUrl" style="width:100%;height:100%;object-fit:cover;" />
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Details -->
            <div class="col-12 col-lg-8">
                <div class="card border-0" style="border-radius:16px;box-shadow:0 2px 16px rgba(0,61,252,.08);">
                    <div class="card-body p-4">

                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h4 class="fw-700 mb-0" style="font-family:'Plus Jakarta Sans',sans-serif;">Villa Details</h4>
                            @if (Model.IsAvilable)
                            {
                                <span style="background:#e8f5e9;color:#2e7d32;font-size:12px;
                                font-weight:600;padding:5px 14px;border-radius:20px;">Available</span>
                            }
                            else
                            {
                                <span style="background:#fce4ec;color:#c62828;font-size:12px;
                                font-weight:600;padding:5px 14px;border-radius:20px;">Unavailable</span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <p class="text-muted mb-4" style="line-height:1.7;font-size:14px;">@Model.Description</p>
                        }

                        <!-- Stats -->
                        <div class="row g-3 mb-4">
                            <div class="col-4">
                                <div class="text-center p-3 rounded-3" style="background:#f0f3ff;">
                                    <i class="bi bi-people-fill d-block mb-2" style="font-size:1.4rem;color:#3252DF;"></i>
                                    <div class="fw-700" style="color:#3252DF;font-family:'Plus Jakarta Sans',sans-serif;">@Model.Capacity</div>
                                    <div class="small text-muted">Guests</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="text-center p-3 rounded-3" style="background:#f0f3ff;">
                                    <i class="bi bi-aspect-ratio d-block mb-2" style="font-size:1.4rem;color:#3252DF;"></i>
                                    <div class="fw-700" style="color:#3252DF;font-family:'Plus Jakarta Sans',sans-serif;">@Model.Sqft</div>
                                    <div class="small text-muted">Sqft</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="text-center p-3 rounded-3" style="background:#f0f3ff;">
                                    <i class="bi bi-cash-stack d-block mb-2" style="font-size:1.4rem;color:#3252DF;"></i>
                                    <div class="fw-700" style="color:#3252DF;font-family:'Plus Jakarta Sans',sans-serif;">$@Model.PricePerNight</div>
                                    <div class="small text-muted">Per Night</div>
                                </div>
                            </div>
                        </div>

                        <!-- Amenities -->
                        @if (Model.VillaAmenity?.Any() == true)
                        {
                            <h6 class="fw-700 mb-3" style="font-family:'Plus Jakarta Sans',sans-serif;">
                                <i class="bi bi-stars me-2" style="color:#003DFC;"></i>Amenities
                            </h6>
                            <div class="row g-2">
                                @foreach (var va in Model.VillaAmenity)
                                {
                                    <div class="col-6 col-md-4">
                                        <div class="d-flex align-items-center gap-2 p-2 rounded-3"
                                             style="background:#f0f3ff;border:1px solid #dce3ff;">
                                            @if (!string.IsNullOrEmpty(va.Amenity?.Icon))
                                            {
                                                <i class="@va.Amenity.Icon" style="color:#003DFC;font-size:16px;flex-shrink:0;"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-check-circle-fill" style="color:#003DFC;font-size:16px;flex-shrink:0;"></i>
                                            }
                                            <div>
                                                <div style="font-size:13px;font-weight:600;
                                                    font-family:'Plus Jakarta Sans',sans-serif;">
                                                    @va.Amenity?.Name
                                                </div>
                                                @if (!string.IsNullOrEmpty(va.Amenity?.Description))
                                                {
                                                    <div style="font-size:11px;color:#6b7280;">@va.Amenity.Description</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small mt-2">
                                <i class="bi bi-info-circle me-1"></i>No amenities assigned.
                            </div>
                        }

                        @if (Model.CreatedDate.HasValue || Model.UpdatedDate.HasValue)
                        {
                            <div class="small text-muted border-top pt-3 mt-4">
                                @if (Model.CreatedDate.HasValue)
                                {
                                    <span class="me-3">
                                        <i class="bi bi-calendar-plus me-1"></i>
                                        Created: @Model.CreatedDate.Value.ToString("MMM dd, yyyy")
                                    </span>
                                }
                                @if (Model.UpdatedDate.HasValue)
                                {
                                    <span>
                                        <i class="bi bi-calendar-check me-1"></i>
                                        Updated: @Model.UpdatedDate.Value.ToString("MMM dd, yyyy")
                                    </span>
                                }
                            </div>
                        }

                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="col-12 col-lg-4">
                <div class="card border-0" style="border-radius:16px;box-shadow:0 2px 16px rgba(0,61,252,.08);">
                    <div class="card-body p-4">
                        <h6 class="fw-700 mb-3" style="font-family:'Plus Jakarta Sans',sans-serif;">Actions</h6>
                        <a asp-action="Edit" asp-route-id="@Model.Id"
                               class="btn text-white w-100 fw-600 mb-2 py-2"
                               style="background:#003DFC;border-radius:12px;border:none;
                            font-family:'Plus Jakarta Sans',sans-serif;">
                            <i class="bi bi-pencil me-2"></i>Edit Villa
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id"
                               class="btn btn-outline-danger w-100 py-2 mb-2" style="border-radius:12px;">
                            <i class="bi bi-trash me-2"></i>Delete Villa
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2"
                               style="border-radius:12px;">
                            <i class="bi bi-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    <script>
        function switchImage(url, el) {
            const img = document.getElementById('main-img');
            if (!img) return;
            img.style.opacity = '0';
            setTimeout(() => { img.src = url; img.style.opacity = '1'; }, 150);
            document.querySelectorAll('[onclick^="switchImage"]').forEach(t => t.style.borderColor = '#e5e7eb');
            el.style.borderColor = '#003DFC';
        }
    </script>
}