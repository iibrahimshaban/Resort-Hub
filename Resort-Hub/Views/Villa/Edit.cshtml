@model Resort_Hub.ViewModels.Villa.VillaFormVM

@{
    ViewData["Title"] = "Edit Villa";
    Layout = "_AdminLayout";
}

<section class="py-5">
    <div class="container" style="max-width:1100px;">

        <div class="mb-4">
            <a asp-action="Index" class="text-decoration-none small" style="color:#3252DF;">
                <i class="bi bi-arrow-left me-1"></i>Back to Villas
            </a>
            <h2 class="fw-700 mt-2 mb-0" style="font-family:'Plus Jakarta Sans',sans-serif;">Edit Villa</h2>
        </div>

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" id="mainImageIndex" name="MainImageIndex" value="0" />

            <div class="row g-4">

                <!-- LEFT: Basic Info -->
                <div class="col-12 col-lg-6">
                    <div class="card border-0 h-100"
                         style="border-radius:16px;box-shadow:0 2px 16px rgba(0,61,252,.08);">
                        <div class="card-body p-4">
                            <h6 class="fw-700 mb-4" style="font-family:'Plus Jakarta Sans',sans-serif;color:#3252DF;">
                                <i class="bi bi-house me-2"></i>Basic Information
                            </h6>

                            <div class="mb-3">
                                <label asp-for="Name" class="form-label fw-600 small">
                                    Villa Name <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Name" class="form-control"
                                       style="border-radius:10px;border-color:#dce3ff;border-width:1.5px;" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Description" class="form-label fw-600 small">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="3"
                                          style="border-radius:10px;border-color:#dce3ff;border-width:1.5px;resize:none;"></textarea>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <label asp-for="PricePerNight" class="form-label fw-600 small">
                                        Price / Night ($) <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"
                                              style="border-radius:10px 0 0 10px;border-color:#dce3ff;
                                        background:#f0f3ff;color:#3252DF;font-weight:600;">$</span>
                                        <input asp-for="PricePerNight" class="form-control" type="number"
                                               step="0.01" min="0"
                                               style="border-radius:0 10px 10px 0;border-color:#dce3ff;" />
                                    </div>
                                    <span asp-validation-for="PricePerNight" class="text-danger small"></span>
                                </div>
                                <div class="col-6">
                                    <label asp-for="Sqft" class="form-label fw-600 small">Area (sqft)</label>
                                    <input asp-for="Sqft" class="form-control" type="number" min="0"
                                           style="border-radius:10px;border-color:#dce3ff;border-width:1.5px;" />
                                </div>
                                <div class="col-6">
                                    <label asp-for="Capacity" class="form-label fw-600 small">Capacity (guests)</label>
                                    <input asp-for="Capacity" class="form-control" type="number" min="0"
                                           style="border-radius:10px;border-color:#dce3ff;border-width:1.5px;" />
                                </div>
                                <div class="col-6 d-flex align-items-end">
                                    <div class="form-check form-switch mb-2">
                                        <input asp-for="IsAvilable" class="form-check-input" type="checkbox"
                                               role="switch" style="width:40px;height:22px;accent-color:#003DFC;" />
                                        <label asp-for="IsAvilable" class="form-check-label fw-600 ms-2 small">Available</label>
                                    </div>
                                </div>
                            </div>

                            <!-- Amenities icons -->
                            @if (Model.AvailableAmenities.Any())
                            {
                                <hr style="border-color:#f0f3ff;" class="my-3" />
                                <h6 class="fw-700 mb-3" style="font-family:'Plus Jakarta Sans',sans-serif;color:#003DFC;">
                                    <i class="bi bi-stars me-2"></i>Amenities
                                </h6>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var amenity in Model.AvailableAmenities)
                                    {
                                        <div>
                                            <input type="checkbox"
                                                   name="SelectedAmenityIds"
                                                   value="@amenity.Id"
                                                   id="amenity_@amenity.Id"
                                                   style="display:none;"
                                            @(Model.SelectedAmenityIds.Contains(amenity.Id) ? "checked" : "")
                                                   onchange="toggleAmenity(this)" />
                                            <label for="amenity_@amenity.Id"
                                                   id="label_@amenity.Id"
                                                   title="@amenity.Name"
                                                   style="width:52px;height:52px;border-radius:12px;cursor:pointer;
                                                display:flex;align-items:center;justify-content:center;
                                                border:2px solid @(Model.SelectedAmenityIds.Contains(amenity.Id) ? "#003DFC" : "#e5e7eb");
                                                background:@(Model.SelectedAmenityIds.Contains(amenity.Id) ? "#f0f3ff" : "transparent");
                                                transition:all .2s;">
                                                @if (!string.IsNullOrEmpty(amenity.Icon))
                                                {
                                                    <i class="@amenity.Icon" id="icon_@amenity.Id"
                                                       style="font-size:1.3rem;color:@(Model.SelectedAmenityIds.Contains(amenity.Id) ? "#003DFC" : "#9ca3af");"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-tag-fill" id="icon_@amenity.Id"
                                                       style="font-size:1.3rem;color:@(Model.SelectedAmenityIds.Contains(amenity.Id) ? "#003DFC" : "#9ca3af");"></i>
                                                }
                                            </label>
                                        </div>
                                    }
                                </div>
                            }

                        </div>
                    </div>
                </div>

                <!-- RIGHT: Images -->
                <div class="col-12 col-lg-6 d-flex flex-column gap-4">

                    <!-- Current Images -->
                    @if (Model.ExistingImages.Any())
                    {
                        <div class="card border-0"
                             style="border-radius:16px;box-shadow:0 2px 16px rgba(0,61,252,.08);">
                            <div class="card-body p-4">
                                <h6 class="fw-700 mb-1" style="font-family:'Plus Jakarta Sans',sans-serif;color:#003DFC;">
                                    <i class="bi bi-images me-2"></i>Current Images
                                </h6>
                                <p class="small text-muted mb-3">Click to new <strong> Main</strong></p>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var img in Model.ExistingImages)
                                    {
                                        <div onclick="setExistingMain(@img.Id, this)"
                                             style="position:relative;width:90px;height:90px;border-radius:10px;
                                            overflow:hidden;cursor:pointer;
                                            border:2px solid @(img.IsMain ? "#003DFC" : "#e5e7eb");
                                            transition:border-color .2s;">
                                            <img src="@img.ImageUrl" style="width:100%;height:100%;object-fit:cover;" />
                                            <span class="existing-main-badge"
                                                  style="position:absolute;bottom:0;left:0;right:0;
                                            background:rgba(0,61,252,.85);color:#fff;
                                            font-size:10px;text-align:center;padding:2px;
                                            display:@(img.IsMain ? "block" : "none");">Main</span>
                                        </div>
                                    }
                                </div>
                                <input type="hidden" id="mainExistingImageId" name="MainExistingImageId"
                                       value="@(Model.ExistingImages.FirstOrDefault(i => i.IsMain)?.Id ?? Model.ExistingImages.First().Id)" />
                            </div>
                        </div>
                    }

                    <!-- Add More Images -->
                    <div class="card border-0"
                         style="border-radius:16px;box-shadow:0 2px 16px rgba(0,61,252,.08);">
                        <div class="card-body p-4">
                            <h6 class="fw-700 mb-1" style="font-family:'Plus Jakarta Sans',sans-serif;color:#003DFC;">
                                <i class="bi bi-cloud-upload me-2"></i>Add More Images
                            </h6>
                            <p class="small text-muted mb-3">Click to add  <strong> new image</strong></p>
                            <div onclick="document.getElementById('img-input').click()"
                                 style="border:2px dashed #dce3ff;border-radius:12px;padding:24px;
                                text-align:center;cursor:pointer;transition:all .2s;"
                                 onmouseenter="this.style.borderColor='#003DFC';this.style.background='#f8f9ff'"
                                 onmouseleave="this.style.borderColor='#dce3ff';this.style.background='transparent'">
                                <i class="bi bi-plus-circle" style="font-size:1.8rem;color:#003DFC;"></i>
                                <p class="mb-0 small text-muted mt-2">Click to add more images</p>
                            </div>
                            <input type="file" id="img-input" name="NewImages" multiple accept="image/*"
                                   class="d-none" onchange="previewImages(this)" />
                            <div id="img-preview" class="d-flex flex-wrap gap-2 mt-3"></div>
                        </div>
                    </div>

                </div>

            </div>

            <!-- Actions -->
            <div class="d-flex gap-2 mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill py-2"
                   style="border-radius:12px;">Cancel</a>
                <button type="submit" class="btn text-white flex-fill py-2 fw-600"
                        style="background:#003DFC;border-radius:12px;border:none;
                    font-family:'Plus Jakarta Sans',sans-serif;">
                    <i class="bi bi-check2 me-2"></i>Save Changes
                </button>
            </div>

        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // ── New images main selector
        function previewImages(input) {
            const preview = document.getElementById('img-preview');
            preview.innerHTML = '';
            document.getElementById('mainImageIndex').value = 0;

            Array.from(input.files).forEach((file, i) => {
                const reader = new FileReader();
                reader.onload = e => {
                    const wrap = document.createElement('div');
                    wrap.dataset.index = i;
                    wrap.style.cssText = `position:relative;width:90px;height:90px;border-radius:10px;
                        overflow:hidden;cursor:pointer;
                        border:2px solid ${i === 0 ? '#003DFC' : '#e5e7eb'};
                        transition:border-color .2s;`;
                    wrap.innerHTML = `
                        <img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;">
                        <span class="new-main-badge" style="position:absolute;bottom:0;left:0;right:0;
                            background:rgba(0,61,252,.85);color:#fff;font-size:10px;
                            text-align:center;padding:2px;
                            display:${i === 0 ? 'block' : 'none'};">Main</span>`;
                    wrap.addEventListener('click', () => setNewMain(i));
                    preview.appendChild(wrap);
                };
                reader.readAsDataURL(file);
            });
        }

        function setNewMain(index) {
            document.getElementById('mainImageIndex').value = index;
            document.querySelectorAll('#img-preview > div').forEach((wrap, i) => {
                const isMain = i === index;
                wrap.style.borderColor = isMain ? '#003DFC' : '#e5e7eb';
                wrap.querySelector('.new-main-badge').style.display = isMain ? 'block' : 'none';
            });
        }

        // ── Existing images main selector
        function setExistingMain(imageId, el) {
            document.getElementById('mainExistingImageId').value = imageId;
            document.querySelectorAll('[onclick^="setExistingMain"]').forEach(wrap => {
                wrap.style.borderColor = '#e5e7eb';
                wrap.querySelector('.existing-main-badge').style.display = 'none';
            });
            el.style.borderColor = '#003DFC';
            el.querySelector('.existing-main-badge').style.display = 'block';
        }

        // ── Amenity toggle
        function toggleAmenity(checkbox) {
            const label = document.getElementById('label_' + checkbox.id.replace('amenity_', ''));
            const icon  = document.getElementById('icon_'  + checkbox.id.replace('amenity_', ''));
            if (checkbox.checked) {
                label.style.borderColor = '#003DFC';
                label.style.background  = '#f0f3ff';
                if (icon) icon.style.color = '#003DFC';
            } else {
                label.style.borderColor = '#e5e7eb';
                label.style.background  = 'transparent';
                if (icon) icon.style.color = '#9ca3af';
            }
        }
    </script>
}